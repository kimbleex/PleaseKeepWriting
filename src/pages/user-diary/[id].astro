---
import Layout from '../../layouts/Layout.astro';

const targetUserId = Astro.params.id;
if (!targetUserId) {
  return Astro.redirect('/users');
}
---

<Layout title="成员日记">
  <div class="user-diary-page" data-user-id={targetUserId}>
    <section class="member-diary-panel">
      <div class="member-diary-head">
        <div class="member-title-block">
          <h1 id="page-title"><span class="skel title-skel"></span></h1>
          <p id="page-sub"><span class="skel sub-skel"></span></p>
        </div>
        <div class="member-diary-tools">
          <label class="date-picker">
            <span>指定日期</span>
            <input type="date" id="date-picker-input" />
          </label>
          <button type="button" class="tool-btn" id="clear-date-btn">全部</button>
          <a href="/users" class="tool-btn back-btn" data-astro-prefetch>返回</a>
        </div>
      </div>

      <div class="date-message" id="date-message" aria-live="polite"></div>

      <div class="member-diary-list" id="diary-feed">
        {Array.from({ length: 6 }).map(() => (
          <article class="member-diary-card diary-skel">
            <span class="skel skel-date"></span>
            <span class="skel skel-line"></span>
            <span class="skel skel-line short"></span>
          </article>
        ))}
      </div>

      <div class="member-diary-pagination" id="member-diary-pagination">
        <button type="button" class="page-btn" id="diary-page-prev">上一页</button>
        <span class="page-info" id="diary-page-info">1 / 1</span>
        <button type="button" class="page-btn" id="diary-page-next">下一页</button>
      </div>
    </section>
  </div>

  <div class="diary-modal" id="diary-modal" aria-hidden="true">
    <div class="diary-modal-backdrop" data-diary-modal-close></div>
    <div class="diary-modal-panel" role="dialog" aria-modal="true" aria-labelledby="diary-modal-title">
      <div class="diary-modal-head">
        <div>
          <h3 id="diary-modal-title">日记详情</h3>
          <p id="diary-modal-meta"></p>
        </div>
        <button type="button" class="diary-modal-close" data-diary-modal-close aria-label="关闭">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
        </button>
      </div>
      <div class="diary-modal-body" id="diary-modal-body"></div>
    </div>
  </div>

  <style is:global>
    html:has(.user-diary-page) {
      height: 100svh;
      overflow-y: scroll;
      scrollbar-gutter: stable;
    }

    body:has(.user-diary-page) {
      height: 100svh;
      overflow: hidden;
    }

    main.container:has(.user-diary-page) {
      height: calc(100svh - var(--member-diary-header-height, 82px));
      padding: clamp(0.5rem, 1svh, 0.78rem) clamp(1rem, 2vw, 1.65rem)
        clamp(0.48rem, 0.8svh, 0.72rem) !important;
      overflow: hidden;
    }

    .user-diary-page {
      height: 100%;
      min-height: 0;
      max-width: none;
      width: 100%;
      margin: 0 auto;
      --panel-pad-y: clamp(0.58rem, 1.05svh, 0.82rem);
      --panel-pad-x: clamp(0.72rem, 1.2vw, 1rem);
      --panel-gap: clamp(0.48rem, 0.9svh, 0.72rem);
    }

    .member-diary-panel {
      height: 100%;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 14px;
      background: #fff;
      box-shadow: 0 6px 22px rgba(15, 23, 42, 0.055);
    }

    .member-diary-head {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--panel-gap);
      padding: var(--panel-pad-y) var(--panel-pad-x);
      border-bottom: 1px solid rgba(15, 23, 42, 0.07);
      background: #f8fafc;
      box-sizing: border-box;
    }

    .member-title-block {
      min-width: 0;
    }

    .member-title-block h1 {
      margin: 0;
      color: #0f172a;
      font-size: 1.02rem;
      font-weight: 900;
      line-height: 1.2;
    }

    .member-title-block p {
      margin: 0.18rem 0 0;
      color: #64748b;
      font-size: 0.76rem;
      line-height: 1.35;
      font-weight: 700;
    }

    .member-diary-tools {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.45rem;
      flex-wrap: wrap;
    }

    .date-picker {
      min-height: 34px;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.35rem 0.2rem 0.58rem;
      border: 1px solid rgba(15, 23, 42, 0.1);
      border-radius: 10px;
      background: #fff;
      color: #64748b;
      font-size: 0.76rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .date-picker input {
      width: 138px;
      min-height: 28px;
      border: 0;
      border-radius: 8px;
      background: #f8fafc;
      color: #0f172a;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 800;
      padding: 0 0.36rem;
      outline: none;
    }

    .date-picker input:focus {
      box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
      background: #fff;
    }

    .tool-btn,
    .page-btn {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: #fff;
      color: #475569;
      border-radius: 9px;
      padding: 0.34rem 0.65rem;
      font: inherit;
      font-size: 0.76rem;
      font-weight: 800;
      line-height: 1;
      cursor: pointer;
      text-decoration: none;
      transition:
        transform 0.16s ease,
        box-shadow 0.16s ease,
        border-color 0.16s ease,
        background 0.16s ease;
    }

    .tool-btn:hover,
    .page-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      border-color: rgba(14, 165, 233, 0.24);
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.07);
    }

    .back-btn {
      color: #0369a1;
      background: #f0f9ff;
      border-color: rgba(14, 165, 233, 0.18);
      line-height: 1;
    }

    .date-message {
      display: none;
      flex: 0 0 auto;
      margin: 0;
      padding: 0.5rem var(--panel-pad-x);
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
      color: #64748b;
      background: #fbfdff;
      font-size: 0.78rem;
      font-weight: 800;
    }

    .date-message.is-visible {
      display: block;
    }

    .member-diary-list {
      flex: 1 1 auto;
      min-height: 0;
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
      display: flex;
      flex-direction: column;
      gap: clamp(0.45rem, 0.9svh, 0.6rem);
      padding: clamp(0.58rem, 1.1svh, 0.78rem) clamp(0.7rem, 1.2vw, 0.9rem);
    }

    .member-diary-list::-webkit-scrollbar {
      width: 8px;
    }

    .member-diary-list::-webkit-scrollbar-thumb {
      border: 2px solid transparent;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.42);
      background-clip: padding-box;
    }

    .member-diary-pagination {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.45rem;
      min-height: clamp(48px, 7svh, 58px);
      padding: clamp(0.45rem, 0.9svh, 0.58rem) clamp(0.65rem, 1.1vw, 0.78rem);
      border-top: 1px solid rgba(15, 23, 42, 0.07);
      background: #fbfdff;
      box-sizing: border-box;
    }

    .page-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .page-info {
      min-width: 120px;
      color: #64748b;
      font-size: 0.76rem;
      font-weight: 800;
      text-align: center;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .member-diary-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
      padding: clamp(0.62rem, 1.1svh, 0.76rem);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 10px;
      background: #fff;
      transition:
        border-color 0.16s ease,
        box-shadow 0.16s ease,
        background 0.16s ease,
        transform 0.16s ease;
    }

    .member-diary-card:hover,
    .member-diary-card.is-highlighted {
      border-color: rgba(14, 165, 233, 0.28);
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.08);
      transform: translateY(-1px);
    }

    .member-diary-card.is-highlighted {
      background: #f0f9ff;
    }

    .diary-main {
      min-width: 0;
    }

    .diary-title-line {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      min-width: 0;
    }

    .diary-title {
      min-width: 0;
      color: #4f46e5;
      font-size: 0.9rem;
      font-weight: 900;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .diary-count {
      flex: 0 0 auto;
      color: #64748b;
      background: #f8fafc;
      border: 1px solid rgba(15, 23, 42, 0.06);
      border-radius: 999px;
      padding: 0.14rem 0.42rem;
      font-size: 0.68rem;
      font-weight: 800;
    }

    .diary-excerpt {
      margin-top: 0.34rem;
      color: #475569;
      font-size: 0.82rem;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      word-break: break-word;
    }

    .diary-view-btn {
      min-height: 32px;
      border: 1px solid rgba(14, 165, 233, 0.18);
      border-radius: 9px;
      background: #f8fafc;
      color: #0369a1;
      padding: 0.34rem 0.62rem;
      font: inherit;
      font-size: 0.74rem;
      font-weight: 850;
      cursor: pointer;
      white-space: nowrap;
    }

    .diary-view-btn:hover {
      background: #f0f9ff;
      border-color: rgba(14, 165, 233, 0.34);
    }

    .empty-state {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 160px;
      color: #94a3b8;
      text-align: center;
      padding: 2rem 1rem;
      border: 1px dashed rgba(15, 23, 42, 0.12);
      border-radius: 12px;
      background: #fff;
      font-size: 0.88rem;
      font-weight: 800;
    }

    .error-state {
      color: #dc2626;
      background: rgba(239, 68, 68, 0.08);
      border-color: rgba(239, 68, 68, 0.2);
    }

    .skel {
      display: inline-block;
      border-radius: 6px;
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
    }

    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .title-skel { width: 180px; height: 1.1rem; }
    .sub-skel { width: 110px; height: 0.75rem; }
    .skel-date { width: 96px; height: 1rem; }
    .skel-line { width: 100%; height: 0.9rem; }
    .skel-line.short { width: 56%; }
    .diary-skel { grid-template-columns: minmax(0, 1fr); align-items: start; }

    .diary-modal {
      position: fixed;
      inset: 0;
      z-index: 1200;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .diary-modal.is-open {
      display: flex;
    }

    .diary-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.34);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    .diary-modal-panel {
      position: relative;
      width: min(760px, calc(100vw - 3rem));
      max-height: min(760px, calc(100svh - 4rem));
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: #fff;
      box-shadow: 0 28px 90px rgba(15, 23, 42, 0.26);
    }

    .diary-modal-head {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.1rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
    }

    .diary-modal-head h3 {
      margin: 0;
      color: #0f172a;
      font-size: 1rem;
      font-weight: 900;
      line-height: 1.25;
    }

    .diary-modal-head p {
      margin: 0.18rem 0 0;
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .diary-modal-close {
      width: 38px;
      height: 38px;
      border-radius: 11px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: #fff;
      color: #64748b;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex: 0 0 auto;
    }

    .diary-modal-body {
      padding: 1.35rem 1.5rem;
      overflow: auto;
      color: #1e293b;
      font-size: 1rem;
      line-height: 1.85;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: "Inter", "Noto Serif SC", Georgia, serif;
    }

    body.diary-modal-open {
      overflow: hidden;
    }

    @media (max-width: 720px) {
      main.container:has(.user-diary-page) {
        height: 100%;
        overflow-y: auto;
        padding: clamp(0.62rem, 1.4svh, 0.9rem) !important;
      }

      .user-diary-page,
      .member-diary-panel {
        height: auto;
      }

      .member-diary-head {
        align-items: stretch;
        flex-direction: column;
      }

      .member-diary-tools {
        justify-content: flex-start;
      }

      .member-diary-card {
        grid-template-columns: 1fr auto;
      }
    }
    @media (max-width: 520px) {
      main.container:has(.user-diary-page) {
        padding: 0.78rem !important;
      }

      .member-diary-head {
        padding: 0.78rem;
      }

      .member-title-block h1 {
        font-size: 0.92rem;
      }

      .member-title-block p,
      .date-message {
        font-size: 0.7rem;
      }

      .member-diary-tools,
      .date-picker {
        width: 100%;
      }

      .date-picker {
        justify-content: space-between;
      }

      .date-picker input {
        width: min(148px, 52vw);
      }

      .tool-btn {
        flex: 1;
        min-height: 30px;
        padding: 0.3rem 0.52rem;
        font-size: 0.7rem;
      }

      .member-diary-list {
        padding: 0.72rem;
      }

      .member-diary-card {
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.58rem;
      }

      .diary-title-line {
        align-items: center;
        flex-wrap: wrap;
        gap: 0.28rem;
      }

      .diary-title {
        font-size: 0.82rem;
      }

      .diary-count {
        font-size: 0.62rem;
      }

      .diary-excerpt {
        font-size: 0.76rem;
      }

      .diary-view-btn {
        min-width: 34px;
        min-height: 34px;
        padding: 0.3rem 0.52rem;
        font-size: 0.72rem;
      }

      .member-diary-pagination {
        justify-content: space-between;
      }

      .page-info {
        min-width: 76px;
        font-size: 0.7rem;
      }

      .diary-modal {
        padding: 0.75rem;
      }

      .diary-modal-panel {
        width: 100%;
        max-height: calc(100svh - 1.5rem);
      }

      .diary-modal-body {
        padding: 1rem;
        font-size: 0.98rem;
        line-height: 1.8;
      }
    }
  </style>

  <script>
    import { navigate } from 'astro:transitions/client';

    type DiaryEntry = {
      id: string;
      dateStr: string;
      content: string;
    };

    type UserDiaryPayload = {
      user: {
        id: string;
        username: string;
      };
      diaries: DiaryEntry[];
    };

    const state = {
      userName: '',
      diaries: [] as DiaryEntry[],
      page: 1,
      pageSize: 1,
      selectedDate: '',
      highlightDate: '',
    };

    function syncMemberDiaryViewport(): void {
      const navbar = document.querySelector<HTMLElement>('.navbar');
      const headerHeight = navbar?.getBoundingClientRect().height ?? 82;
      document.documentElement.style.setProperty('--member-diary-header-height', `${Math.ceil(headerHeight)}px`);
    }

    function escapeHTML(value: unknown): string {
      const entities: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return String(value).replace(/[&<>"']/g, (char: string) => entities[char] ?? char);
    }

    function excerpt(content: string): string {
      const compact = content.replace(/\s+/g, ' ').trim();
      return compact.length > 150 ? `${compact.slice(0, 150)}...` : compact || '空日记';
    }

    function getPageCount(): number {
      return Math.max(1, Math.ceil(state.diaries.length / Math.max(1, state.pageSize)));
    }

    function clampPage(): void {
      state.page = Math.min(Math.max(1, state.page), getPageCount());
    }

    function measurePageSize(): number {
      if (window.innerWidth <= 720) return 6;
      const list = document.getElementById('diary-feed');
      const firstCard = list?.querySelector<HTMLElement>('.member-diary-card');
      if (!list || !firstCard) return state.pageSize || 1;
      const listHeight = list.clientHeight;
      const cardHeight = firstCard.getBoundingClientRect().height;
      const style = window.getComputedStyle(list);
      const gap = Number.parseFloat(style.rowGap || style.gap || '0') || 0;
      if (listHeight <= 0 || cardHeight <= 0) return state.pageSize || 1;
      return Math.max(1, Math.ceil((listHeight + gap) / (cardHeight + gap)));
    }

    function syncPageSizeFromLayout(): boolean {
      const nextPageSize = measurePageSize();
      if (nextPageSize === state.pageSize) return false;
      state.pageSize = nextPageSize;
      clampPage();
      return true;
    }

    function setDateMessage(message = ''): void {
      const el = document.getElementById('date-message');
      if (!el) return;
      el.textContent = message;
      el.classList.toggle('is-visible', Boolean(message));
    }

    function updatePagination(): void {
      clampPage();
      const totalPages = getPageCount();
      const prev = document.getElementById('diary-page-prev') as HTMLButtonElement | null;
      const next = document.getElementById('diary-page-next') as HTMLButtonElement | null;
      const info = document.getElementById('diary-page-info');
      if (prev) prev.disabled = state.page <= 1;
      if (next) next.disabled = state.page >= totalPages;
      if (info) info.textContent = `${state.page} / ${totalPages} · 每页 ${state.pageSize} 篇`;
    }

    function openDiaryModal(diary: DiaryEntry): void {
      const modal = document.getElementById('diary-modal');
      const title = document.getElementById('diary-modal-title');
      const meta = document.getElementById('diary-modal-meta');
      const body = document.getElementById('diary-modal-body');
      if (title) title.textContent = `${state.userName} 的日记`;
      if (meta) meta.textContent = diary.dateStr;
      if (body) body.textContent = diary.content;
      modal?.classList.add('is-open');
      modal?.setAttribute('aria-hidden', 'false');
      document.body.classList.add('diary-modal-open');
    }

    function closeDiaryModal(): void {
      const modal = document.getElementById('diary-modal');
      modal?.classList.remove('is-open');
      modal?.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('diary-modal-open');
    }

    function renderList(allowRemeasure = true): void {
      const feed = document.getElementById('diary-feed');
      if (!feed) return;

      if (state.diaries.length === 0) {
        feed.innerHTML = '<div class="empty-state">该成员还没有写过日记...</div>';
        updatePagination();
        return;
      }

      clampPage();
      const start = (state.page - 1) * state.pageSize;
      const pageItems = state.diaries.slice(start, start + state.pageSize);
      feed.innerHTML = pageItems.map((diary) => `
        <article class="member-diary-card ${diary.dateStr === state.highlightDate ? 'is-highlighted' : ''}" data-diary-id="${escapeHTML(diary.id)}">
          <div class="diary-main">
            <div class="diary-title-line">
              <span class="diary-title">${escapeHTML(diary.dateStr)}</span>
              <span class="diary-count">${diary.content.length} 字</span>
            </div>
            <div class="diary-excerpt">${escapeHTML(excerpt(diary.content))}</div>
          </div>
          <button type="button" class="diary-view-btn" data-view-diary="${escapeHTML(diary.id)}">查看</button>
        </article>
      `).join('');

      feed.querySelectorAll<HTMLButtonElement>('[data-view-diary]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const diary = state.diaries.find((item) => item.id === btn.dataset.viewDiary);
          if (diary) openDiaryModal(diary);
        });
      });

      feed.scrollTop = 0;
      updatePagination();
      if (allowRemeasure && syncPageSizeFromLayout()) renderList(false);
    }

    function jumpToDate(dateStr: string): void {
      state.selectedDate = dateStr;
      state.highlightDate = '';
      if (!dateStr) {
        setDateMessage('');
        state.page = 1;
        renderList();
        return;
      }

      const index = state.diaries.findIndex((diary) => diary.dateStr === dateStr);
      if (index < 0) {
        setDateMessage(`${dateStr} 没有可查看的日记`);
        renderList();
        return;
      }

      state.highlightDate = dateStr;
      state.page = Math.floor(index / Math.max(1, state.pageSize)) + 1;
      setDateMessage(`已定位到 ${dateStr} 的日记`);
      renderList();
    }

    function bindHandlers(): void {
      const prev = document.getElementById('diary-page-prev') as HTMLButtonElement | null;
      const next = document.getElementById('diary-page-next') as HTMLButtonElement | null;
      if (prev && prev.dataset.bound !== '1') {
        prev.dataset.bound = '1';
        prev.addEventListener('click', () => {
          state.page -= 1;
          state.highlightDate = '';
          renderList();
        });
      }
      if (next && next.dataset.bound !== '1') {
        next.dataset.bound = '1';
        next.addEventListener('click', () => {
          state.page += 1;
          state.highlightDate = '';
          renderList();
        });
      }

      const dateInput = document.getElementById('date-picker-input') as HTMLInputElement | null;
      if (dateInput && dateInput.dataset.bound !== '1') {
        dateInput.dataset.bound = '1';
        dateInput.addEventListener('change', () => jumpToDate(dateInput.value));
      }

      const clearBtn = document.getElementById('clear-date-btn') as HTMLButtonElement | null;
      if (clearBtn && clearBtn.dataset.bound !== '1') {
        clearBtn.dataset.bound = '1';
        clearBtn.addEventListener('click', () => {
          if (dateInput) dateInput.value = '';
          jumpToDate('');
        });
      }

      document.querySelectorAll<HTMLElement>('[data-diary-modal-close]').forEach((item) => {
        if (item.dataset.bound === '1') return;
        item.dataset.bound = '1';
        item.addEventListener('click', (event) => {
          event.preventDefault();
          closeDiaryModal();
        });
      });
    }

    async function loadUserDiary(): Promise<void> {
      const page = document.querySelector('.user-diary-page');
      const userId = page?.getAttribute('data-user-id');
      if (!userId) return;

      const feed = document.getElementById('diary-feed');
      try {
        const res = await fetch(`/api/user-diary-data?id=${encodeURIComponent(userId)}`);
        if (res.status === 401) {
          navigate('/login');
          return;
        }
        if (res.status === 403) {
          navigate('/users');
          return;
        }
        if (!res.ok) {
          if (feed) feed.innerHTML = '<div class="empty-state error-state">加载失败，请稍后再试</div>';
          return;
        }

        const data = (await res.json()) as UserDiaryPayload;
        state.userName = data.user.username;
        state.diaries = data.diaries;
        state.page = 1;
        document.title = `${data.user.username} 的日记 - 我们的日记`;
        const title = document.getElementById('page-title');
        const sub = document.getElementById('page-sub');
        if (title) title.textContent = `${data.user.username} 的日记`;
        if (sub) sub.textContent = `${data.diaries.length} 篇记录`;
        renderList();
      } catch (error) {
        console.error(error);
        if (feed) feed.innerHTML = '<div class="empty-state error-state">加载失败，请稍后再试</div>';
      }
    }

    document.addEventListener('astro:page-load', () => {
      syncMemberDiaryViewport();
      bindHandlers();
      void loadUserDiary();
    });

    document.addEventListener('keydown', (event) => {
      const modal = document.getElementById('diary-modal');
      if (event.key === 'Escape' && modal?.classList.contains('is-open')) closeDiaryModal();
    });

    window.addEventListener('resize', () => {
      syncMemberDiaryViewport();
      renderList();
    });
  </script>
</Layout>
