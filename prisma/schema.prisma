generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  diaries           Diary[]
  reports           DiaryReport[]
  sentRequests      PermissionRequest[] @relation("Requester")
  receivedRequests  PermissionRequest[] @relation("Target")
}

enum Role {
  ADMIN
  USER
}

model Diary {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model DiaryReport {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        ReportType
  status      ReportStatus @default(PENDING)
  periodStart DateTime     @db.Date
  periodEnd   DateTime     @db.Date
  title       String
  content     String?
  error       String?
  modelName   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, type, periodStart])
  @@index([userId, type, periodStart])
}

enum ReportType {
  WEEK
  MONTH
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  ERROR
}

model PermissionRequest {
  id          String        @id @default(uuid())
  requesterId String
  targetId    String
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id])
  target    User @relation("Target", fields: [targetId], references: [id])

  @@unique([requesterId, targetId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  tag         String   @default("系统公告")
  summary     String
  body        String
  pinned      Boolean  @default(false)
  publishedAt DateTime @db.Date
  readUserIds Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@index([pinned])
}
