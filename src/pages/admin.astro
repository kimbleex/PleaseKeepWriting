---
import Layout from '../layouts/Layout.astro';
import { prisma } from '../lib/db';
import { hashPassword } from '../lib/auth';

let message = '';
let isError = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const username = data.get('username') as string;
  const password = data.get('password') as string;

  if (!username || !password) {
    message = '请填写完整信息';
    isError = true;
  } else {
    try {
      const existingUser = await prisma.user.findUnique({ where: { username } });
      if (existingUser) {
        message = '用户名已存在';
        isError = true;
      } else {
        const passwordHash = await hashPassword(password);
        await prisma.user.create({ data: { username, passwordHash, role: 'USER' } });
        message = `用户 ${username} 创建成功！`;
      }
    } catch (e) {
      message = '创建用户失败';
      isError = true;
      console.error(e);
    }
  }
}

const users = await prisma.user.findMany({ orderBy: { createdAt: 'desc' } });
const adminCount = users.filter(u => u.role === 'ADMIN').length;
const userCount = users.filter(u => u.role === 'USER').length;
---
<Layout title="管理面板">
  <div class="admin-wrap">

    <div class="admin-grid">
      <!-- Create member card -->
      <div class="card">
        <div class="card-header">
          <div class="card-icon create-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <h2 class="card-title">创建新成员</h2>
        </div>

        {message && (
          <div class={`msg-bar ${isError ? 'msg-error' : 'msg-success'}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {isError
                ? <Fragment><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></Fragment>
                : <Fragment><polyline points="20 6 9 17 4 12"/></Fragment>
              }
            </svg>
            {message}
          </div>
        )}

        <form method="POST" class="create-form">
          <div class="field">
            <label for="username" class="field-label">用户名</label>
            <input
              type="text"
              id="username"
              name="username"
              class="field-input"
              placeholder="输入新成员用户名"
              required
              autocomplete="off"
            />
          </div>
          <div class="field">
            <label for="password" class="field-label">初始密码</label>
            <input
              type="password"
              id="password"
              name="password"
              class="field-input"
              placeholder="设置初始密码"
              required
            />
          </div>
          <button type="submit" class="create-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            创建账号
          </button>
        </form>
      </div>

      <!-- Member list card -->
      <div class="card">
        <div class="card-header" style="justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 0.85rem;">
            <div class="card-icon list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h2 class="card-title">成员列表</h2>
          </div>
          <div class="header-stats" style="padding: 0.4rem 1.25rem;">
            <div class="hstat">
              <span class="hstat-num">{users.length}</span>
              <span class="hstat-label">总成员</span>
            </div>
            <div class="hstat-sep"></div>
            <div class="hstat">
              <span class="hstat-num" style="color:#818cf8">{adminCount}</span>
              <span class="hstat-label">管理员</span>
            </div>
            <div class="hstat-sep"></div>
            <div class="hstat">
              <span class="hstat-num" style="color:#34d399">{userCount}</span>
              <span class="hstat-label">普通成员</span>
            </div>
          </div>
        </div>

        <div class="member-list">
          {users.map((u, idx) => (
            <div class="member-row">
              <div class="member-left">
                <div class={`member-avatar ${u.role === 'ADMIN' ? 'avatar-admin' : 'avatar-user'}`}>
                  {u.username.charAt(0).toUpperCase()}
                </div>
                <div class="member-info">
                  <span class="member-name">{u.username}</span>
                  <span class="member-date">加入于 {u.createdAt.toISOString().split('T')[0]}</span>
                </div>
              </div>
              <div class="member-right">
                {u.role === 'ADMIN'
                  ? <span class="role-badge role-admin">管理员</span>
                  : <span class="role-badge role-user">成员</span>
                }
              </div>
            </div>
          ))}
          {users.length === 0 && (
            <div class="empty-hint">暂无成员</div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .admin-wrap {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Page header */
  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-title {
    font-size: 1.9rem;
    font-weight: 700;
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .page-sub {
    font-size: 0.85rem;
    color: #94a3b8;
    margin-top: 0.3rem;
  }

  .header-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: #f8fafc;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    padding: 0.75rem 1.5rem;
    backdrop-filter: blur(10px);
  }

  .hstat { text-align: center; }
  .hstat-num {
    display: block;
    font-size: 1.4rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1;
  }
  .hstat-label {
    display: block;
    font-size: 0.72rem;
    color: #94a3b8;
    margin-top: 0.25rem;
  }
  .hstat-sep {
    width: 1px;
    height: 32px;
    background: rgba(0,0,0,0.08);
  }

  /* Grid */
  .admin-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .admin-grid { grid-template-columns: 1fr; }
  }

  /* Card */
  .card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .create-icon {
    background: rgba(99,102,241,0.15);
    color: #818cf8;
    border: 1px solid rgba(99,102,241,0.25);
  }

  .list-icon {
    background: rgba(16,185,129,0.12);
    background: rgba(16,185,129,0.1);
    color: #059669;
    border: 1px solid rgba(16,185,129,0.2);
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #0f172a;
  }

  /* Message bar */
  .msg-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .msg-error {
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
    color: #dc2626;
  }

  .msg-success {
    background: rgba(16,185,129,0.1);
    border: 1px solid rgba(16,185,129,0.2);
    color: #059669;
  }

  /* Form */
  .create-form { display: flex; flex-direction: column; gap: 1.25rem; }  .field { display: flex; flex-direction: column; gap: 0.4rem; }

  .field-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: #64748b;
    letter-spacing: 0.03em;
  }

  .field-input {
    padding: 0.7rem 1rem;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.1);
    background: #f8fafc;
    color: #0f172a;
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .field-input::placeholder { color: #94a3b8; }
  .field-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.18);
  }

  .create-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    font-family: inherit;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;
    box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    margin-top: 0.25rem;
  }
  .create-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(99,102,241,0.45);
  }

  /* Member list */
  .member-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 480px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }

  .member-list::-webkit-scrollbar { width: 4px; }
  .member-list::-webkit-scrollbar-track { background: transparent; }
  .member-list::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 2px; }

  .member-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.05);
    background: #f8fafc;
    transition: border-color 0.15s;
  }
  .member-row:hover {
    background: #f1f5f9;
    border-color: rgba(0,0,0,0.1);
  }

  .member-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .member-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .avatar-admin {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    box-shadow: 0 2px 8px rgba(99,102,241,0.3);
  }

  .avatar-user {
    background: linear-gradient(135deg, #059669, #047857);
    color: white;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .member-name {
    font-weight: 500;
    font-size: 0.9rem;
    color: #0f172a;
  }

  .member-date {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .role-badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .role-admin {
    background: rgba(99,102,241,0.1);
    color: #6366f1;
    border: 1px solid rgba(99,102,241,0.2);
  }

  .role-user {
    background: rgba(16,185,129,0.1);
    color: #059669;
    border: 1px solid rgba(16,185,129,0.2);
  }

  .empty-hint {
    text-align: center;
    color: #94a3b8;
    padding: 2rem;
    font-size: 0.9rem;
  }
</style>
