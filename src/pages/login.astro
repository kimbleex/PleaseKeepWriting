---
import '../styles/global.css';

const unlock = Astro.url.searchParams.get('unlock') === '1';
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登录 - 我们的日记</title>
    <style>
      .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }
      .login-box {
        max-width: 400px;
        width: 100%;
      }
      .login-box h1 {
        text-align: center;
        margin-bottom: 2rem;
        font-size: 2rem;
        background: linear-gradient(to right, #818cf8, #c084fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .login-note {
        padding: 0.85rem 1rem;
        margin-bottom: 1.25rem;
        border-radius: 8px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.16);
        color: #4f46e5;
        font-size: 0.9rem;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <div class="login-container">
      <div class="glass-panel login-box">
        <h1>欢迎回来</h1>
        {unlock && <div class="login-note">本地日记已加密，请重新输入密码。</div>}
        <div class="alert" id="client-error" hidden></div>
        <form method="POST" id="login-form" data-ready="0" onsubmit="if (this.dataset.ready !== '1') return false;">
          <div class="input-group">
            <label for="username">用户名</label>
            <input type="text" id="username" name="username" class="input-control" autocomplete="username" required autofocus />
          </div>
          <div class="input-group">
            <label for="password">密码</label>
            <input type="password" id="password" name="password" class="input-control" autocomplete="current-password" required />
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;" id="login-submit" disabled>准备中...</button>
        </form>
        <div class="text-center mt-4">
          <p style="font-size: 0.85rem; color: #94a3b8;">只有超级管理员可以创建新成员账号</p>
        </div>
      </div>
    </div>
    <script>
      import { deriveAndStoreLocalPrivacyKey } from '../lib/localCrypto';

      function safeNextPath(): string {
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next') || '/';
        if (!next.startsWith('/') || next.startsWith('//')) return '/';
        return next;
      }

      const form = document.getElementById('login-form') as HTMLFormElement | null;
      const errorEl = document.getElementById('client-error');
      const submit = document.getElementById('login-submit') as HTMLButtonElement | null;

      if (form && submit && form.dataset.bound !== '1') {
        form.dataset.bound = '1';
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const username = String(new FormData(form).get('username') ?? '');
          const password = String(new FormData(form).get('password') ?? '');
          if (errorEl) errorEl.hidden = true;
          submit.disabled = true;
          submit.textContent = '登录中...';

          try {
            const res = await fetch('/api/client-login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({ username, password }),
            });
            const payload = await res.json().catch(() => ({}));
            if (!res.ok || !payload?.user?.id) {
              throw new Error(payload.error || '登录失败，请重试');
            }
            await deriveAndStoreLocalPrivacyKey(payload.user.id, password);
            window.location.assign(safeNextPath());
          } catch (error) {
            if (errorEl) {
              errorEl.textContent = error instanceof Error ? error.message : '登录失败，请重试';
              errorEl.hidden = false;
            }
            submit.disabled = false;
            submit.textContent = '登录系统';
          }
        });
        form.dataset.ready = '1';
        submit.disabled = false;
        submit.textContent = '登录系统';
      }
    </script>
  </body>
</html>
