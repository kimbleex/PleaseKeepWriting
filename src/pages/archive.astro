    }

    .agent-composer textarea {
      width: 100%;
      min-height: 28px;
      max-height: 32px;
      resize: none;
      border: 0;
      border-radius: 10px;
      padding: 0.24rem 0.14rem;
      color: #0f172a;
      background: transparent;
      font: inherit;
      font-size: 0.84rem;
      line-height: 1.45;
      outline: none;
      overflow-y: auto;
      transition:
        min-height 0.18s ease,
        max-height 0.18s ease;
    }

    .agent-composer.is-expanded textarea {
      min-height: clamp(90px, 18svh, 118px);
      max-height: clamp(118px, 26svh, 152px);
    }

    .composer-send-btn {
      align-self: end;
      min-width: 64px;
      min-height: 34px;
      border-color: rgba(15, 23, 42, 0.16);
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.24rem;
      padding: 0 0.58rem;
      color: #fff;
      font-size: 0.74rem;
      background: linear-gradient(135deg, #1e293b 0%, #0369a1 100%);
      box-shadow:
        0 8px 18px rgba(15, 23, 42, 0.13),
