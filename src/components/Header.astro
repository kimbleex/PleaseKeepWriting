---
const { user, url } = Astro.props;
const pathname = (url as URL)?.pathname ?? '/';
const showHomeSync = true ;

type NavItem = { href: string; label: string; icon: string };
const navItems: NavItem[] = [
  {
    href: '/',
    label: '日历',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    href: '/diary',
    label: '写日记',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  },
  {
    href: '/archive',
    label: '日记归档',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8"/><path d="M3 8l1.68-4.23A2 2 0 0 1 6.54 2h10.92a2 2 0 0 1 1.86 1.77L21 8"/><path d="M10 12h4"/></svg>`,
  },
  {
    href: '/users',
    label: '成员',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
if (user.role === 'ADMIN') {
  navItems.push({
    href: '/admin',
    label: '管理',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  });
}
---

<header class="navbar">
  <div class="container header-inner">
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
      </div>
      <span class="logo-text">我们的日记</span>
    </a>

    <nav class="nav-pills">
      {navItems.map((item) => {
        const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
        return (
          <a href={item.href} class={`nav-pill${isActive ? ' active' : ''}`} data-nav-key={item.href === '/users' ? 'members' : undefined} data-astro-prefetch>
            <span class="nav-icon" set:html={item.icon} />
            <span class="nav-label">{item.label}</span>
            {item.href === '/users' && <span class="nav-alert-dot" data-member-request-dot aria-label="有待处理的成员申请"></span>}
          </a>
        );
      })}
    </nav>

    <div class="user-area">
      <button type="button" class="announcement-btn" id="announcement-btn" title="查看公告" aria-haspopup="dialog" aria-expanded="false">
        <span class="announcement-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 0 1-5.8-1.6"/></svg>
        </span>
        <span class="announcement-label">公告</span>
        <span class="announcement-alert-dot" aria-label="有未读公告"></span>
      </button>
      {showHomeSync && (
        <button type="button" class="home-sync-btn" id="home-sync-btn" title="同步数据" aria-live="polite">
          <span class="home-sync-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 1-15.5 6.2L3 16"/><path d="M3 16v5h5"/><path d="M3 12A9 9 0 0 1 18.5 5.8L21 8"/><path d="M21 8V3h-5"/></svg>
          </span>
          <span class="home-sync-label">同步数据</span>
        </button>
      )}
      <div class="user-menu">
        <button type="button" class={`user-chip user-menu-trigger${pathname.startsWith('/permissions') ? ' active' : ''}`} aria-haspopup="menu" aria-expanded="false" title="打开账号菜单">
          <div class="user-avatar-sm">{user.username.charAt(0).toUpperCase()}</div>
          <span class="user-chip-name">{user.username}</span>
          {user.role === 'ADMIN' && <span class="admin-dot" title="管理员"></span>}
          <span class="user-chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </span>
        </button>
        <div class="user-dropdown" role="menu">
          <div class="user-menu-head">
            <div class="user-avatar-sm menu-avatar">{user.username.charAt(0).toUpperCase()}</div>
            <div class="user-menu-meta">
              <span class="user-menu-name">{user.username}</span>
              <span class="user-menu-role">{user.role === 'ADMIN' ? '管理员' : '成员'}</span>
            </div>
          </div>
          <a href="/permissions" class={`user-menu-item${pathname.startsWith('/permissions') ? ' active' : ''}`} role="menuitem" data-astro-prefetch>
            <span class="user-menu-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.68 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
            </span>
            <span>权限管理</span>
          </a>
          <button type="button" class="user-menu-item" role="menuitem" data-open-change-password>
            <span class="user-menu-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M15 7a2 2 0 1 1 2 2"/><path d="M9.5 14.5 5 19l-2-2 4.5-4.5"/><path d="M13.5 10.5 21 3"/><path d="m16 3 5 5"/><path d="M14 14a6 6 0 1 1-4-4"/></svg>
            </span>
            <span>修改密码</span>
          </button>
          <form method="POST" action="/api/logout" id="logout-form" class="user-menu-form">
            <button type="submit" class="user-menu-item danger" role="menuitem">
              <span class="user-menu-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              </span>
              <span>退出登录</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</header>

<div class="announcement-overlay" id="announcement-modal" aria-hidden="true">
  <section class="announcement-dialog" role="dialog" aria-modal="true" aria-labelledby="announcement-modal-title">
    <div class="announcement-head">
      <div class="announcement-head-main">
        <span class="announcement-kicker">更新公告</span>
        <h2 id="announcement-modal-title">公告</h2>
      </div>
      <div class="announcement-head-actions">
        <button type="button" class="announcement-mark-all" id="announcement-mark-all">全部已读</button>
        <button type="button" class="announcement-close" id="announcement-close" title="关闭公告" aria-label="关闭公告">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>
    <div class="announcement-shell">
      <aside class="announcement-list" id="announcement-list" aria-label="公告列表">
        <div class="announcement-loading">公告加载中...</div>
      </aside>
      <article class="announcement-detail" id="announcement-detail">
        <div class="announcement-empty">选择一篇公告查看内容</div>
      </article>
    </div>
  </section>
</div>

<div class="password-overlay" id="change-password-modal" aria-hidden="true">
  <section class="password-dialog" role="dialog" aria-modal="true" aria-labelledby="change-password-title">
    <div class="password-dialog-hero">
      <div class="password-hero-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M15 7a2 2 0 1 1 2 2"/><path d="M9.5 14.5 5 19l-2-2 4.5-4.5"/><path d="M13.5 10.5 21 3"/><path d="m16 3 5 5"/><path d="M14 14a6 6 0 1 1-4-4"/></svg>
      </div>
      <div class="password-hero-copy">
        <span class="password-kicker">账号安全</span>
        <h2 id="change-password-title">修改密码</h2>
      </div>
      <button type="button" class="password-close" id="change-password-close" aria-label="关闭修改密码">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <form class="password-form" id="change-password-form">
      <div class="password-field">
        <label for="current-password">原密码</label>
        <input id="current-password" name="currentPassword" type="password" autocomplete="current-password" required />
      </div>
      <div class="password-field">
        <label for="new-password">新密码</label>
        <input id="new-password" name="newPassword" type="password" autocomplete="new-password" minlength="8" maxlength="128" required />
      </div>
      <div class="password-field">
        <label for="confirm-password">确认新密码</label>
        <input id="confirm-password" name="confirmPassword" type="password" autocomplete="new-password" minlength="8" maxlength="128" required />
      </div>
      <p class="password-status" id="change-password-status" aria-live="polite"></p>
      <div class="password-actions">
        <button type="button" class="password-secondary" data-close-change-password>取消</button>
        <button type="submit" class="password-primary" id="change-password-submit">
          <span class="password-submit-label">确认修改</span>
          <span class="password-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </form>
    <div class="password-success" id="change-password-success" aria-hidden="true">
      <div class="password-success-mark">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h3>密码已更新</h3>
      <p>正在退出当前登录状态...</p>
    </div>
  </section>
</div>

<style is:global>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.06);
  }

  .header-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 2px 10px rgba(99, 102, 241, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .logo:hover .logo-icon {
    transform: rotate(-6deg) scale(1.08);
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.5);
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 700;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-pills {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .nav-pill {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.42rem 0.85rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    text-decoration: none;
    transition: all 0.18s ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .nav-pill:hover {
    color: #1e293b;
    background: rgba(0, 0, 0, 0.05);
  }

  .nav-pill.active {
    color: #6366f1;
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.18);
  }

  .nav-alert-dot {
    position: absolute;
    top: 0.36rem;
    right: 0.5rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #fb7185, #ef4444);
    border: 1.5px solid rgba(255, 255, 255, 0.96);
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.34);
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
    transition: opacity 0.16s ease, transform 0.16s ease;
  }

  .nav-alert-dot::after {
    content: "";
    position: absolute;
    inset: -0.32rem;
    border-radius: inherit;
    border: 1px solid rgba(239, 68, 68, 0.28);
    opacity: 0;
    transform: scale(0.35);
  }

  .nav-pill.has-alert .nav-alert-dot {
    opacity: 1;
    transform: scale(1);
    animation: nav-alert-breathe 1.8s ease-in-out infinite;
  }

  .nav-pill.has-alert .nav-alert-dot::after {
    animation: nav-alert-ring 1.8s ease-out infinite;
  }

  @keyframes nav-alert-breathe {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3);
    }
    50% {
      box-shadow: 0 0 0 0.18rem rgba(239, 68, 68, 0);
    }
  }

  @keyframes nav-alert-ring {
    0% {
      opacity: 0.65;
      transform: scale(0.35);
    }
    70%,
    100% {
      opacity: 0;
      transform: scale(1.1);
    }
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .user-area {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .announcement-btn {
    position: relative;
    height: 34px;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0 0.78rem;
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(254, 243, 199, 0.95), rgba(209, 250, 229, 0.9)),
      #ffffff;
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #92400e;
    font-size: 0.78rem;
    font-weight: 750;
    font-family: inherit;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(245, 158, 11, 0.16);
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .announcement-btn:hover,
  .announcement-btn.is-open {
    transform: translateY(-1px);
    background:
      linear-gradient(135deg, rgba(253, 230, 138, 0.98), rgba(167, 243, 208, 0.94)),
      #ffffff;
    border-color: rgba(245, 158, 11, 0.48);
    color: #78350f;
    box-shadow: 0 10px 28px rgba(245, 158, 11, 0.22);
  }

  .announcement-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .announcement-alert-dot {
    position: absolute;
    top: 0.34rem;
    right: 0.42rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #fb7185, #ef4444);
    border: 1.5px solid rgba(255, 255, 255, 0.96);
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.34);
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
    transition: opacity 0.16s ease, transform 0.16s ease;
  }

  .announcement-alert-dot::after {
    content: "";
    position: absolute;
    inset: -0.32rem;
    border-radius: inherit;
    border: 1px solid rgba(239, 68, 68, 0.28);
    opacity: 0;
    transform: scale(0.35);
  }

  .announcement-btn.has-alert .announcement-alert-dot {
    opacity: 1;
    transform: scale(1);
    animation: nav-alert-breathe 1.8s ease-in-out infinite;
  }

  .announcement-btn.has-alert .announcement-alert-dot::after {
    animation: nav-alert-ring 1.8s ease-out infinite;
  }

  .user-menu {
    position: relative;
  }

  .user-chip {
    height: 34px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.28rem 0.75rem 0.28rem 0.32rem;
    border-radius: 6px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-family: inherit;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, box-shadow 0.18s;
  }

  .user-chip:hover,
  .user-chip.active,
  .user-menu.is-open .user-chip {
    background: rgba(99, 102, 241, 0.06);
    border-color: rgba(99, 102, 241, 0.2);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.12);
  }

  .home-sync-btn {
    height: 34px;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0 0.78rem;
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.12));
    border: 1px solid rgba(99, 102, 241, 0.22);
    color: #5b5fee;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(99, 102, 241, 0.12);
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .home-sync-btn:hover {
    transform: translateY(-1px);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.16), rgba(168, 85, 247, 0.18));
    border-color: rgba(99, 102, 241, 0.34);
    box-shadow: 0 10px 28px rgba(99, 102, 241, 0.18);
  }

  .home-sync-btn:disabled {
    cursor: default;
    transform: none;
    opacity: 0.78;
  }

  .home-sync-btn.is-syncing .home-sync-icon {
    animation: home-sync-spin 0.9s linear infinite;
  }

  .home-sync-btn.is-success {
    color: #059669;
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.22);
  }

  .home-sync-btn.is-error {
    color: #dc2626;
    background: rgba(239, 68, 68, 0.09);
    border-color: rgba(239, 68, 68, 0.22);
  }

  .home-sync-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes home-sync-spin {
    to { transform: rotate(360deg); }
  }

  .user-avatar-sm {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.72rem;
    flex-shrink: 0;
  }

  .user-chip-name {
    font-size: 0.82rem;
    font-weight: 500;
    color: #475569;
    max-width: 120px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

