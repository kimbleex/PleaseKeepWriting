---
import Layout from '../layouts/Layout.astro';
---

<Layout title="管理面板">
  <div class="admin-wrap">
    <div class="admin-grid">
      <section class="card">
        <div class="card-header">
          <div class="card-icon create-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <h2 class="card-title">创建新成员</h2>
        </div>

        <div id="admin-msg"></div>

        <form method="POST" class="create-form" id="create-user-form">
          <div class="field">
            <label for="username" class="field-label">用户名</label>
            <input type="text" id="username" name="username" class="field-input" placeholder="输入新成员用户名" required autocomplete="off" />
          </div>
          <div class="field">
            <label for="password" class="field-label">初始密码</label>
            <input type="password" id="password" name="password" class="field-input" placeholder="设置初始密码" required />
          </div>
          <button type="submit" class="create-btn" id="create-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <span id="create-label">创建账号</span>
          </button>
        </form>
      </section>

      <section class="card">
        <div class="card-header card-header-split">
          <div class="header-title">
            <div class="card-icon list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h2 class="card-title">成员列表</h2>
          </div>
          <div class="header-stats">
            <div class="hstat"><span class="hstat-num" id="total-count"><span class="skel stat-skel"></span></span><span class="hstat-label">总成员</span></div>
            <div class="hstat-sep"></div>
            <div class="hstat"><span class="hstat-num admin-num" id="admin-count"><span class="skel stat-skel"></span></span><span class="hstat-label">管理员</span></div>
            <div class="hstat-sep"></div>
            <div class="hstat"><span class="hstat-num user-num" id="user-count"><span class="skel stat-skel"></span></span><span class="hstat-label">普通成员</span></div>
          </div>
        </div>

        <div class="member-list" id="member-list">
          {Array.from({ length: 5 }).map(() => (
            <div class="member-row">
              <div class="member-left">
                <span class="skel avatar-skel"></span>
                <div class="member-info">
                  <span class="skel name-skel"></span>
                  <span class="skel date-skel"></span>
                </div>
              </div>
              <span class="skel role-skel"></span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>

  <style>
    .skel { display:inline-block; background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:6px; }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .stat-skel { width:36px; height:1.4rem; }
    .avatar-skel { width:36px; height:36px; border-radius:50%; flex-shrink:0; }
    .name-skel { width:110px; height:0.9rem; }
    .date-skel { width:92px; height:0.75rem; }
    .role-skel { width:64px; height:1.4rem; border-radius:999px; }
    .admin-wrap { max-width:1100px; margin:0 auto; }
    .admin-grid { display:grid; grid-template-columns:380px 1fr; gap:1.5rem; align-items:start; }
    .card { background:#ffffff; border:1px solid rgba(0,0,0,0.07); border-radius:20px; padding:1.75rem; box-shadow:0 4px 20px rgba(0,0,0,0.06); }
    .card-header { display:flex; align-items:center; gap:0.85rem; margin-bottom:1.5rem; padding-bottom:1.25rem; border-bottom:1px solid rgba(0,0,0,0.06); }
    .card-header-split { justify-content:space-between; }
    .header-title { display:flex; align-items:center; gap:0.85rem; }
    .card-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .create-icon { background:rgba(99,102,241,0.15); color:#818cf8; border:1px solid rgba(99,102,241,0.25); }
    .list-icon { background:rgba(16,185,129,0.1); color:#059669; border:1px solid rgba(16,185,129,0.2); }
    .card-title { font-size:1.15rem; font-weight:700; color:#0f172a; margin:0; }
    .msg-bar { display:flex; align-items:center; gap:0.5rem; padding:0.75rem 1rem; border-radius:10px; font-size:0.875rem; margin-bottom:1.25rem; }
    .msg-error { background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#dc2626; }
    .msg-success { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); color:#059669; }
    .create-form { display:flex; flex-direction:column; gap:1.25rem; }
    .field { display:flex; flex-direction:column; gap:0.4rem; }
    .field-label { font-size:0.82rem; font-weight:500; color:#64748b; letter-spacing:0.03em; }
    .field-input { padding:0.7rem 1rem; border-radius:10px; border:1px solid rgba(0,0,0,0.1); background:#f8fafc; color:#0f172a; font-family:inherit; font-size:0.95rem; transition:border-color 0.2s, box-shadow 0.2s; outline:none; }
    .field-input::placeholder { color:#94a3b8; }
    .field-input:focus { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,0.18); }
    .create-btn { display:flex; align-items:center; justify-content:center; gap:0.5rem; padding:0.8rem 1.5rem; border-radius:10px; background:linear-gradient(135deg,#6366f1,#8b5cf6); color:white; font-weight:600; font-size:0.95rem; font-family:inherit; border:none; cursor:pointer; transition:transform 0.2s, box-shadow 0.2s, opacity 0.2s; box-shadow:0 4px 14px rgba(99,102,241,0.35); margin-top:0.25rem; }
    .create-btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(99,102,241,0.45); }
    .create-btn:disabled { cursor:wait; opacity:0.72; transform:none; }
    .header-stats { display:flex; align-items:center; gap:1.25rem; background:#f8fafc; border:1px solid rgba(0,0,0,0.07); border-radius:12px; padding:0.4rem 1.25rem; }
    .hstat { text-align:center; }
    .hstat-num { display:block; font-size:1.4rem; font-weight:700; color:#0f172a; line-height:1; min-width:36px; }
    .admin-num { color:#818cf8; }
    .user-num { color:#34d399; }
    .hstat-label { display:block; font-size:0.72rem; color:#94a3b8; margin-top:0.25rem; }
    .hstat-sep { width:1px; height:32px; background:rgba(0,0,0,0.08); }
    .member-list { display:flex; flex-direction:column; gap:0.5rem; max-height:480px; overflow-y:auto; padding-right:0.25rem; }
    .member-list::-webkit-scrollbar { width:4px; }
    .member-list::-webkit-scrollbar-thumb { background:rgba(0,0,0,0.1); border-radius:2px; }
    .member-row { display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1rem; border-radius:12px; border:1px solid rgba(0,0,0,0.05); background:#f8fafc; transition:border-color 0.15s; gap:0.75rem; }
    .member-row:hover { background:#f1f5f9; border-color:rgba(0,0,0,0.1); }
    .member-left { display:flex; align-items:center; gap:0.75rem; min-width:0; }
    .member-avatar { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem; flex-shrink:0; }
    .avatar-admin { background:linear-gradient(135deg,#6366f1,#8b5cf6); color:white; box-shadow:0 2px 8px rgba(99,102,241,0.3); }
    .avatar-user { background:linear-gradient(135deg,#059669,#047857); color:white; }
    .member-info { display:flex; flex-direction:column; gap:0.1rem; min-width:0; }
    .member-name { font-weight:500; font-size:0.9rem; color:#0f172a; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .member-date { font-size:0.75rem; color:#94a3b8; }
    .role-badge { display:inline-block; padding:0.2rem 0.65rem; border-radius:999px; font-size:0.75rem; font-weight:600; white-space:nowrap; }
    .role-admin { background:rgba(99,102,241,0.1); color:#6366f1; border:1px solid rgba(99,102,241,0.2); }
    .role-user { background:rgba(16,185,129,0.1); color:#059669; border:1px solid rgba(16,185,129,0.2); }
    .empty-hint { text-align:center; color:#94a3b8; padding:2rem; font-size:0.9rem; }
    @media (max-width:860px) {
      .admin-grid { grid-template-columns:1fr; }
      .card-header-split { align-items:flex-start; flex-direction:column; }
      .header-stats { width:100%; justify-content:center; }
    }
  </style>

  <script>
    type AdminUser = {
      id: string;
      username: string;
      role: 'ADMIN' | 'USER';
      initial: string;
      createdDate: string;
    };

    type AdminData = {
      users: AdminUser[];
      totalCount: number;
      adminCount: number;
      userCount: number;
    };

    type CreateUserResponse = {
      ok: boolean;
      message?: string;
      error?: string;
    };

    function getEl<T extends HTMLElement>(id: string): T | null {
      return document.getElementById(id) as T | null;
    }

    function setText(id: string, value: string | number): void {
      const el = getEl(id);
      if (el) el.textContent = String(value);
    }

    function escapeHTML(value: unknown): string {
      const entities: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      };
      return String(value).replace(/[&<>"']/g, (char: string) => entities[char] ?? char);
    }

    function showAdminMsg(text: string, isError: boolean): void {
      const area = getEl('admin-msg');
      if (!area) return;
      area.innerHTML = `<div class="msg-bar ${isError ? 'msg-error' : 'msg-success'}">${escapeHTML(text)}</div>`;
    }

    async function loadAdminData(): Promise<void> {
      const list = getEl('member-list');
      try {
        const res = await fetch('/api/admin-data');
        if (!res.ok) return;
        const data = (await res.json()) as AdminData;
        setText('total-count', data.totalCount);
        setText('admin-count', data.adminCount);
        setText('user-count', data.userCount);
        if (!list) return;
        if (data.users.length === 0) {
          list.innerHTML = '<div class="empty-hint">暂无成员</div>';
          return;
        }
        list.innerHTML = data.users.map((user: AdminUser) => `
          <div class="member-row">
            <div class="member-left">
              <div class="member-avatar ${user.role === 'ADMIN' ? 'avatar-admin' : 'avatar-user'}">${escapeHTML(user.initial)}</div>
              <div class="member-info">
                <span class="member-name">${escapeHTML(user.username)}</span>
                <span class="member-date">加入于 ${escapeHTML(user.createdDate)}</span>
              </div>
            </div>
            <div class="member-right">
              <span class="role-badge ${user.role === 'ADMIN' ? 'role-admin' : 'role-user'}">${user.role === 'ADMIN' ? '管理员' : '成员'}</span>
            </div>
          </div>`).join('');
      } catch (error) {
        console.error(error);
      }
    }

    function attachCreateForm(): void {
      const form = getEl<HTMLFormElement>('create-user-form');
      const button = getEl<HTMLButtonElement>('create-btn');
      const label = getEl<HTMLSpanElement>('create-label');
      if (!form || !button || !label) return;
      form.addEventListener('submit', async (event: SubmitEvent) => {
        event.preventDefault();
        const body = new FormData(form);
        button.disabled = true;
        label.textContent = '创建中...';
        try {
          const res = await fetch('/api/create-user', { method: 'POST', body });
          const json = (await res.json()) as CreateUserResponse;
          showAdminMsg(json.message || json.error || '操作失败', !json.ok);
          if (json.ok) {
            form.reset();
            await loadAdminData();
          }
        } catch (error) {
          console.error(error);
          showAdminMsg('创建用户失败，请稍后再试', true);
        } finally {
          button.disabled = false;
          label.textContent = '创建账号';
        }
      }, { once: true });
    }

    document.addEventListener('astro:page-load', () => {
      void loadAdminData();
      attachCreateForm();
    });
  </script>
</Layout>
