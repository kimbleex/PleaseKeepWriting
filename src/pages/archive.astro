      .panel-head,
      .agent-head {
        align-items: center;
        flex-direction: row;
        justify-content: space-between;
        gap: 0.48rem;
        padding: 0.68rem;
      }

      .daily-head-main {
        width: 100%;
        align-items: center;
        flex-direction: row;
        justify-content: space-between;
        gap: 0.48rem;
      }

      .daily-tools {
        width: auto;
        margin-left: 0;
        flex-direction: row;
        align-items: center;
        gap: 0.28rem;
      }

      .sync-action,
      .clear-chat-btn {
        width: auto;
      }

      .daily-panel,
      .agent-panel {
        min-height: 360px;
      }

      .panel-head h1,
      .agent-head h2,
      .agent-name {
        font-size: 0.88rem;
      }

      .panel-head p,
      .agent-head p,
      .agent-status {
        font-size: 0.66rem;
      }

      .filter-btn,
      .sync-action,
      .clear-chat-btn,
      .composer-send-btn {
        min-height: 28px;
        padding: 0.28rem 0.48rem;
        font-size: 0.7rem;
      }

      .daily-list,
      .chat-stream {
        padding: 0.72rem;
      }

      .daily-item {
        grid-template-columns: auto minmax(0, 1fr) 34px;
        gap: 0.58rem;
        padding: 0.72rem;
      }

      .daily-title-row {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.3rem;
      }

      .daily-badge {
        width: fit-content;
      }

      .daily-pagination {
        justify-content: space-between;
      }

      .page-info {
        min-width: 64px;
        font-size: 0.7rem;
      }

      .page-btn,
      .daily-view-btn {
        min-height: 30px;
        padding: 0.3rem 0.52rem;
        font-size: 0.7rem;
      }

      .chat-row {
        max-width: 100%;
      }

      .agent-empty {
        align-items: stretch;
        flex-direction: column;
        width: 100%;
      }

      .agent-empty span {
        text-align: center;
      }

      .daily-modal {
        padding: 1rem;
      }

      .daily-modal-panel {
        width: 100%;
        max-height: calc(100svh - 2rem);
      }
    }
  </style>

  <script>
    import { DIARY_AGENT_NAME as CLIENT_DIARY_AGENT_NAME } from "../lib/agent/skills/diaryAssistantSkill";
    import { navigate } from "astro:transitions/client";
    import {
      getArchiveDiaryDaysLocal,
      getLocalPrivacyUnlockUrl,
      isLocalPrivacyKeyMissing,
      syncSelectedDiaries,
    } from "../lib/localFirst";

    type DailyFilter = "all" | "synced" | "unsynced";
    type DailyItem = {
      id: string;
      dateStr: string;
      content: string;
      preview: string;
      updatedAt: string;
      synced: boolean;
    };

    type AgentEvent =
      | { type: "start" }
      | { type: "token"; node: string; text: string }
      | { type: "node"; node: string; title: string; detail?: string }
      | { type: "tool_call"; node: string; name: string; args: unknown }
      | {
          type: "tool_result";
          node: string;
          name: string;
          detail: string;
          raw?: string;
        }
      | { type: "final"; text: string }
      | { type: "error"; message: string }
      | { type: "done" };

    type AgentShell = {
      wrap: HTMLElement;
      progress: HTMLElement;
      answerRow: HTMLElement;
      bubble: HTMLElement;
      meta: HTMLElement;
      toolSummaries: string[];
      answerStarted: boolean;
      progressKeys: Set<string>;
      bufferedText: string;
      shouldRefreshDays: boolean;
    };

    const AGENT_NAME = CLIENT_DIARY_AGENT_NAME;

    const state = {
      days: [] as DailyItem[],
      filter: "all" as DailyFilter,
      page: 1,
      pageSize: 3,
      selectedIds: new Set<string>(),
      sending: false,
    };
    const archiveWindow = window as typeof window & {
      __archiveSyncListenerAttached?: boolean;
      __dailyModalEscapeAttached?: boolean;
    };

    function redirectForPrivacyUnlock(error: unknown): boolean {
      if (!isLocalPrivacyKeyMissing(error)) return false;
      navigate(getLocalPrivacyUnlockUrl());
      return true;
    }

    function syncArchiveViewport() {
      const header = document.querySelector(".navbar");
      const headerHeight = header
        ? Math.ceil(header.getBoundingClientRect().height)
        : 82;
      document.documentElement.style.setProperty(
        "--archive-header-height",
        `${headerHeight}px`,
      );
    }

    function escapeHTML(value: unknown): string {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return String(value).replace(
        /[&<>"']/g,
        (char: string) => entities[char] ?? char,
      );
    }

    function formatDateLabel(dateStr: string): string {
      const [year, month, day] = dateStr.split("-");
      return `${year}年${month}月${day}日`;
    }

    function filteredDays(): DailyItem[] {
      if (state.filter === "synced")
        return state.days.filter((day) => day.synced);
      if (state.filter === "unsynced")
        return state.days.filter((day) => !day.synced);
      return state.days;
    }

    function renderSummary() {
      const summary = document.getElementById("daily-summary");
      if (!summary) return;
      const total = state.days.length;
      const unsynced = state.days.filter((day) => !day.synced).length;
      summary.textContent = `${total} 篇，${unsynced} 篇未同步`;
    }

    function refreshSyncButton() {
      const btn = document.getElementById(
        "sync-selected-btn",
      ) as HTMLButtonElement | null;
      if (!btn) return;
      const count = [...state.selectedIds].filter((id) =>
        state.days.some((day) => day.id === id && !day.synced),
      ).length;
      btn.disabled = count === 0;
      btn.textContent = count > 0 ? `同步所选 (${count})` : "同步所选";
    }

    function syncPageSizeFromLayout(): boolean {
      if (window.innerWidth <= 980) {
        if (state.pageSize === 8) return false;
        state.pageSize = 8;
        state.page = Math.min(state.page, getTotalPages(filteredDays().length));
        return true;
      }

      const list = document.getElementById("daily-list");
      const firstItem = list?.querySelector<HTMLElement>(
        ".daily-item:not(.daily-skel)",
      );
      if (!list || !firstItem) return false;

      const listHeight = list.clientHeight;
      const itemHeight = firstItem.getBoundingClientRect().height;
      const style = window.getComputedStyle(list);
      const gap = Number.parseFloat(style.rowGap || style.gap || "0") || 0;
      if (listHeight <= 0 || itemHeight <= 0) return false;

      const nextSize = Math.max(
        1,
        Math.floor((listHeight + gap) / (itemHeight + gap)),
      );
      if (nextSize === state.pageSize) return false;

      state.pageSize = nextSize;
      state.page = Math.min(state.page, getTotalPages(filteredDays().length));
      return true;
    }

    function getTotalPages(total: number): number {
      return Math.max(1, Math.ceil(total / Math.max(1, state.pageSize)));
    }

    function renderPagination(total: number, totalPages: number) {
      const pagination = document.getElementById("daily-pagination");
      const info = document.getElementById("daily-page-info");
      const prev = document.getElementById(
        "daily-page-prev",
      ) as HTMLButtonElement | null;
      const next = document.getElementById(
        "daily-page-next",
      ) as HTMLButtonElement | null;
      if (!pagination || !info || !prev || !next) return;

      pagination.hidden = total === 0;
      info.textContent = `${state.page} / ${totalPages} · 每页 ${state.pageSize} 篇`;
      prev.disabled = state.page <= 1;
      next.disabled = state.page >= totalPages;
    }

    function renderDailyList(allowRemeasure = true) {
      const list = document.getElementById("daily-list");
      if (!list) return;
      const days = filteredDays();
      if (!days.length) {
        list.innerHTML = '<div class="empty-list">没有匹配的日报</div>';
        renderPagination(0, 1);
        refreshSyncButton();
        return;
      }

      const totalPages = getTotalPages(days.length);
      if (state.page > totalPages) state.page = totalPages;
      if (state.page < 1) state.page = 1;
      const start = (state.page - 1) * state.pageSize;
      const pageItems = days.slice(start, start + state.pageSize);

      list.innerHTML = pageItems
        .map(
          (day) => `
        <div class="daily-item ${day.synced ? "" : "is-unsynced"}" data-id="${day.id}" data-date="${day.dateStr}">
          <input type="checkbox" class="daily-check" data-check-id="${day.id}" ${state.selectedIds.has(day.id) ? "checked" : ""} ${day.synced ? "disabled" : ""} aria-label="选择 ${escapeHTML(day.dateStr)}" />
          <div class="daily-main">
            <div class="daily-title-row">
              <div class="daily-title">${escapeHTML(formatDateLabel(day.dateStr))}</div>
              <span class="daily-badge ${day.synced ? "synced" : "unsynced"}">${day.synced ? "已同步" : "未同步"}</span>
            </div>
            <div class="daily-text">${escapeHTML(day.preview)}</div>
            <div class="daily-meta">${escapeHTML(day.updatedAt.replace("T", " ").slice(0, 16))}</div>
          </div>
          <button type="button" class="daily-view-btn" data-view-id="${day.id}" aria-label="查看 ${escapeHTML(day.dateStr)} 的日报" title="查看">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      `,
        )
        .join("");
      list.scrollTop = 0;

      list.querySelectorAll<HTMLElement>(".daily-item").forEach((item) => {
        item.addEventListener("click", () => {
          const date = item.dataset.date ?? "";
          const input = document.getElementById(
            "agent-input",
          ) as HTMLTextAreaElement | null;
          if (input && date) input.value = `总结 ${date} 的日记`;
        });
      });

      list
        .querySelectorAll<HTMLInputElement>(".daily-check")
        .forEach((checkbox) => {
          checkbox.addEventListener("click", (event) =>
            event.stopPropagation(),
          );
          checkbox.addEventListener("change", () => {
            const id = checkbox.dataset.checkId ?? "";
            if (!id) return;
            if (checkbox.checked) state.selectedIds.add(id);
            else state.selectedIds.delete(id);
            refreshSyncButton();
          });
        });

      list
        .querySelectorAll<HTMLButtonElement>(".daily-view-btn")
        .forEach((btn) => {
          btn.addEventListener("click", (event) => {
            event.stopPropagation();
            const id = btn.dataset.viewId ?? "";
            openDailyModal(id);
          });
        });

      renderPagination(days.length, totalPages);
      refreshSyncButton();

      if (allowRemeasure && syncPageSizeFromLayout()) {
        renderDailyList(false);
      }
    }

    async function loadDays() {
      try {
        const rows = await getArchiveDiaryDaysLocal();
        state.days = rows.map((row) => ({
          id: row.localId,
          dateStr: row.dateStr,
          content: row.content,
          preview: row.preview,
          updatedAt: row.updatedAt,
          synced: !row.needsSync,
        }));
      } catch (localError) {
        if (redirectForPrivacyUnlock(localError)) throw localError;
        console.error(
          "local archive data failed, falling back to server api",
          localError,
        );
        const res = await fetch("/api/archive-data");
        if (!res.ok) throw new Error(`归档数据加载失败：${res.status}`);
        const data = await res.json();
        state.days = (data.diaryDays ?? []).map((row: any) => ({
          id: row.id,
          dateStr: row.dateStr,
          content: row.content,
          preview: row.preview,
          updatedAt: row.updatedAt,
          synced: true,
        }));
      }
      renderSummary();
      renderDailyList();
    }

    function openDailyModal(id: string) {
      const day = state.days.find((item) => item.id === id);
      const modal = document.getElementById("daily-modal");
      const title = document.getElementById("daily-modal-title");
      const meta = document.getElementById("daily-modal-meta");
      const body = document.getElementById("daily-modal-body");
      if (!day || !modal || !title || !meta || !body) return;

      title.textContent = formatDateLabel(day.dateStr);
      meta.textContent = `${day.synced ? "已同步" : "未同步"} · ${day.updatedAt.replace("T", " ").slice(0, 16)}`;
      body.textContent = day.content;
      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("daily-modal-open");
    }

    function closeDailyModal() {
      const modal = document.getElementById("daily-modal");
      if (!modal) return;
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("daily-modal-open");
    }

    function setAgentStatus(text: string) {
      const el = document.getElementById("agent-status");
      if (!el) return;
      const statusText = el.querySelector(".status-text");
      if (statusText) statusText.textContent = text;
      else el.textContent = text;
      const running = text.includes("运行");
      el.classList.toggle("is-running", running);
      el.classList.toggle("is-ready", !running);
    }

    function chatStreamEl(): HTMLElement | null {
      return document.getElementById("chat-stream");
    }

    function clearEmptyState() {
      document.querySelector(".agent-empty")?.remove();
    }

    function getCurrentUserAvatarText(): string {
      const avatar = document.querySelector<HTMLElement>(".user-avatar-sm");
      return avatar?.textContent?.trim() || "我";
    }

    function getCurrentUserName(): string {
      const name = document.querySelector<HTMLElement>(".user-chip-name");
      return name?.textContent?.trim() || "我";
    }

    function createAvatar(className: string, text: string): HTMLElement {
      const avatar = document.createElement("div");
      avatar.className = `chat-avatar ${className}`;
      avatar.textContent = text.slice(0, 2).toUpperCase();
      return avatar;
    }

    function normalizeAgentOutput(text: string): string {
      let output = text
        .replace(/(^|\n)\s{0,3}#{1,6}\s+/g, "$1")
        .replace(/\*\*(.*?)\*\*/g, "$1")
        .replace(/(^|\n)\s*[-*]\s+/g, "$1")
        .trim();

      const numberedAnswer = output.match(/(?:^|\n)(\s*1[.、]\s[\s\S]*)/);
      if (numberedAnswer) {
        const prefix = output.slice(0, numberedAnswer.index ?? 0);
        if (
          /[{[]|"\w+"|query_my_diaries_by_date_range|updated_at|content|entries/.test(
            prefix,
          )
        ) {
          output = numberedAnswer[1] ?? output;
        }
      }

      output = output
        .replace(
          /^我(?:看了|查看了|查询了|检索了)你?[\s\S]{0,180}?日记[。.]?\s*/,
          "",
        )
        .replace(/(^|\n)\s{0,3}#{1,6}\s+/g, "$1")
        .replace(/\*\*(.*?)\*\*/g, "$1")
        .replace(/(^|\n)\s*[-*]\s+/g, "$1")
        .replace(/\n{3,}/g, "\n\n")
        .trim();

      return output;
    }

    function appendUserMessage(text: string) {
      const stream = chatStreamEl();
      if (!stream) return;
      clearEmptyState();
      const wrap = document.createElement("div");
      wrap.className = "chat-row user";
      const avatar = createAvatar("user-avatar", getCurrentUserAvatarText());
      const body = document.createElement("div");
      body.className = "chat-body";
      const name = document.createElement("div");
      name.className = "chat-name";
      name.textContent = getCurrentUserName();
      const bubble = document.createElement("div");
      bubble.className = "msg-bubble";
      bubble.textContent = text;
      body.append(name, bubble);
      wrap.append(avatar, body);
      stream.appendChild(wrap);
      stream.scrollTop = stream.scrollHeight;
    }

    function setLoadingBubble(bubble: HTMLElement) {
      bubble.classList.add("is-loading");
      bubble.setAttribute("aria-label", "正在加载");
      bubble.textContent = "";
      const dots = document.createElement("span");
      dots.className = "loading-dots";
      dots.append(
        document.createElement("span"),
        document.createElement("span"),
        document.createElement("span"),
      );
      bubble.appendChild(dots);
    }

    function clearLoadingBubble(bubble: HTMLElement) {
      bubble.classList.remove("is-loading");
      bubble.removeAttribute("aria-label");
      bubble.textContent = "";
    }

    function appendAgentShell(): AgentShell | null {
      const stream = chatStreamEl();
      if (!stream) return null;
      clearEmptyState();
      const wrap = document.createElement("div");
      wrap.className = "agent-turn";
      const progress = document.createElement("div");
      progress.className = "stream-stack";
      const answerRow = document.createElement("div");
      answerRow.className = "chat-row agent";
      const avatar = createAvatar("agent-avatar", AGENT_NAME);
      const body = document.createElement("div");
      body.className = "chat-body";
      const name = document.createElement("div");
      name.className = "chat-name";
      name.textContent = AGENT_NAME;
      const meta = document.createElement("div");
      meta.className = "answer-meta";
      const bubble = document.createElement("div");
      bubble.className = "msg-bubble";
      setLoadingBubble(bubble);
      body.append(name, meta, bubble);
      answerRow.append(avatar, body);
      wrap.append(progress, answerRow);
      stream.appendChild(wrap);
      stream.scrollTop = stream.scrollHeight;
      return {
        wrap,
        progress,
        answerRow,
        bubble,
        meta,
        toolSummaries: [],
        answerStarted: true,
        progressKeys: new Set<string>(),
        bufferedText: "",
        shouldRefreshDays: false,
      };
    }

    function markStreamStepsDone(progress: HTMLElement) {
      progress.querySelectorAll<HTMLElement>(".stream-step").forEach((step) => {
        step.classList.add("is-done");
      });
    }

    function streamNodeLabel(node: string): string {
      if (node === "model") return "model";
      if (node === "tools") return "tool";
      if (node === "agent") return "agent";
      return node.replace(/_/g, " ");
    }

    function appendStreamStep(
      shell: AgentShell,
      node: string,
      title: string,
      detail = "",
      raw = "",
      collapsible = false,
      key = "",
    ) {
      if (key && shell.progressKeys.has(key)) return;
      markStreamStepsDone(shell.progress);
      if (key) shell.progressKeys.add(key);
      const step = document.createElement(collapsible ? "details" : "div");
      step.className = `stream-step${collapsible ? " tool-step" : ""}`;

      const line = document.createElement(collapsible ? "summary" : "div");
      line.className = "stream-line";
      const spinner = document.createElement("span");
      spinner.className = "stream-spinner";
      const nodeEl = document.createElement("span");
      nodeEl.className = "stream-node";
      nodeEl.textContent = streamNodeLabel(node);
      const titleEl = document.createElement("span");
      titleEl.className = "stream-title";
      titleEl.textContent = title;
      line.append(spinner, nodeEl, titleEl);
      step.appendChild(line);

      if (detail && !collapsible) {
        const detailEl = document.createElement("div");
        detailEl.className = "stream-detail";
        detailEl.textContent = detail;
        step.appendChild(detailEl);
      }

      if (collapsible) {
        const detailEl = document.createElement("div");
        detailEl.className = "stream-detail";
        detailEl.textContent = detail || "工具已返回结果";
        const rawEl = document.createElement("pre");
        rawEl.className = "tool-raw";
        rawEl.textContent = raw || detail || "无可展开内容";
        step.append(detailEl, rawEl);
      }

      shell.progress.appendChild(step);
      const stream = chatStreamEl();
      if (stream) stream.scrollTop = stream.scrollHeight;
    }

    function appendAnswerProgress(shell: AgentShell, node = "model_request") {
      appendStreamStep(shell, node, "模型生成回答", "", "", false, "answer");
    }

    function updateAnswerMeta(shell: AgentShell) {
      if (shell.toolSummaries.length === 0) return;
      shell.meta.classList.add("is-visible");
      const unique = [...new Set(shell.toolSummaries)];
      shell.meta.textContent = `已参考 ${unique.length} 次查询：${unique.slice(-1)[0]}`;
    }

    function ensureAgentAnswer(shell: AgentShell) {
      if (!shell.answerStarted) {
        shell.answerStarted = true;
        shell.answerRow.hidden = false;
        updateAnswerMeta(shell);
      }
    }

    function wait(ms: number): Promise<void> {
      return new Promise((resolve) => window.setTimeout(resolve, ms));
    }

    async function replayAgentAnswer(shell: AgentShell) {
      const text = normalizeAgentOutput(shell.bufferedText);
      ensureAgentAnswer(shell);
      clearLoadingBubble(shell.bubble);
      updateAnswerMeta(shell);

      if (!text) {
        shell.bubble.textContent = "没有生成可展示的回答。";
        return;
      }

      for (const chunk of Array.from(text)) {
        shell.bubble.textContent += chunk;
        const stream = chatStreamEl();
        if (stream) stream.scrollTop = stream.scrollHeight;
        await wait(chunk === "\n" ? 28 : 8);
      }
    }

    function appendAgentError(text: string) {
      const stream = chatStreamEl();
      if (!stream) return;
      clearEmptyState();
      const wrap = document.createElement("div");
      wrap.className = "chat-row agent";
      const avatar = createAvatar("agent-avatar", AGENT_NAME);
      const body = document.createElement("div");
      body.className = "chat-body";
      const name = document.createElement("div");
      name.className = "chat-name";
      name.textContent = AGENT_NAME;
      const bubble = document.createElement("div");
      bubble.className = "msg-bubble error";
      bubble.textContent = text;
      body.append(name, bubble);
      wrap.append(avatar, body);
      stream.appendChild(wrap);
      stream.scrollTop = stream.scrollHeight;
    }

    function stringifyArgs(args: unknown): string {
      try {
        if (args && typeof args === "object" && "content" in args) {
          const nextArgs = { ...(args as Record<string, unknown>) };
          const content = String(nextArgs.content ?? "");
          nextArgs.content =
            content.length > 80 ? `${content.slice(0, 80)}...` : content;
          return JSON.stringify(nextArgs);
        }
        return JSON.stringify(args);
      } catch {
        return String(args);
      }
    }

    async function sendAgentMessage(text: string) {
      if (state.sending) return;
      state.sending = true;
      setAgentStatus("运行中");
      const sendBtn = document.getElementById(
        "agent-send-btn",
      ) as HTMLButtonElement | null;
      if (sendBtn) sendBtn.disabled = true;
      appendUserMessage(text);
      const shell = appendAgentShell();

      try {
        const response = await fetch("/api/agent-chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message: text }),
        });

        if (!response.ok || !response.body) {
          const payload = await response.json().catch(() => ({}));
          throw new Error(payload.error || `请求失败：${response.status}`);
        }

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split("\n");
          buffer = lines.pop() ?? "";

          for (const rawLine of lines) {
            const line = rawLine.trim();
            if (!line) continue;
            const event = JSON.parse(line) as AgentEvent;
            if (!shell) continue;

            if (event.type === "start") {
              appendStreamStep(
                shell,
                "agent",
                `${AGENT_NAME} 正在读取问题`,
                "",
                "",
                false,
                "read",
              );
            } else if (event.type === "node") {
              if (event.title === "模型生成回答") {
                appendAnswerProgress(shell, event.node);
              }
            } else if (event.type === "tool_call") {
              appendStreamStep(
                shell,
                event.node,
                `调用工具：${event.name}`,
                stringifyArgs(event.args),
                "",
                false,
                "tool",
              );
            } else if (event.type === "tool_result") {
              shell.toolSummaries.push(event.detail);
              if (event.name === "upsert_my_today_diary")
                shell.shouldRefreshDays = true;
            } else if (event.type === "token") {
              appendAnswerProgress(shell, event.node);
              shell.bufferedText += event.text;
            } else if (event.type === "final" && !shell.bufferedText.trim()) {
              appendAnswerProgress(shell);
              shell.bufferedText = event.text;
            } else if (event.type === "error") {
              ensureAgentAnswer(shell);
              clearLoadingBubble(shell.bubble);
              shell.bubble.classList.add("error");
              shell.bubble.textContent = event.message;
            } else if (event.type === "done") {
              if (shell.bufferedText.trim()) appendAnswerProgress(shell);
              markStreamStepsDone(shell.progress);
              await replayAgentAnswer(shell);
              if (shell.shouldRefreshDays) {
                await loadDays();
              }
              setAgentStatus("就绪");
            }

            const stream = chatStreamEl();
            if (stream) stream.scrollTop = stream.scrollHeight;
          }
        }
      } catch (error) {
        if (redirectForPrivacyUnlock(error)) return;
        if (shell) {
          ensureAgentAnswer(shell);
          markStreamStepsDone(shell.progress);
          clearLoadingBubble(shell.bubble);
          shell.bubble.classList.add("error");
          shell.bubble.textContent =
            error instanceof Error ? error.message : "发送失败";
        } else {
          appendAgentError(error instanceof Error ? error.message : "发送失败");
        }
      } finally {
        state.sending = false;
        setAgentStatus("就绪");
        if (sendBtn) sendBtn.disabled = false;
      }
    }

    function attachHandlers() {
      document
        .querySelectorAll<HTMLElement>("[data-daily-modal-close]")
        .forEach((item) => {
          item.addEventListener("click", (event) => {
            event.preventDefault();
            closeDailyModal();
          });
        });

      if (!archiveWindow.__dailyModalEscapeAttached) {
        archiveWindow.__dailyModalEscapeAttached = true;
        document.addEventListener("keydown", (event) => {
          const modal = document.getElementById("daily-modal");
          if (event.key === "Escape" && modal?.classList.contains("is-open"))
            closeDailyModal();
        });
      }

      document
        .querySelectorAll<HTMLButtonElement>(".filter-btn")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            state.filter = (btn.dataset.filter ?? "all") as DailyFilter;
            state.page = 1;
            document
              .querySelectorAll(".filter-btn")
              .forEach((item) =>
                item.classList.toggle("is-active", item === btn),
              );
            renderDailyList();
          });
        });

      const prevPage = document.getElementById(
        "daily-page-prev",
      ) as HTMLButtonElement | null;
      const nextPage = document.getElementById(
        "daily-page-next",
      ) as HTMLButtonElement | null;
      prevPage?.addEventListener("click", () => {
        state.page -= 1;
        renderDailyList();
      });
      nextPage?.addEventListener("click", () => {
        state.page += 1;
        renderDailyList();
      });

      const syncBtn = document.getElementById(
        "sync-selected-btn",
      ) as HTMLButtonElement | null;
      syncBtn?.addEventListener("click", async () => {
        const ids = [...state.selectedIds].filter((id) =>
          state.days.some((day) => day.id === id && !day.synced),
        );
        if (!ids.length) return;
        syncBtn.disabled = true;
        syncBtn.textContent = "同步中...";
        try {
          await syncSelectedDiaries(ids);
          ids.forEach((id) => state.selectedIds.delete(id));
          await loadDays();
        } catch (error) {
          if (redirectForPrivacyUnlock(error)) return;
          throw error;
        } finally {
          refreshSyncButton();
        }
      });

      const form = document.getElementById(
        "agent-form",
      ) as HTMLFormElement | null;
      const input = document.getElementById(
        "agent-input",
      ) as HTMLTextAreaElement | null;
      const expandBtn = document.getElementById(
        "agent-expand-btn",
      ) as HTMLButtonElement | null;

      function hasComposerContent() {
        return Boolean(input?.value.trim());
      }

      function setComposerExpanded(expanded: boolean) {
        if (!form) return;
        const nextExpanded = expanded && hasComposerContent();
        form.classList.toggle("is-expanded", nextExpanded);
        expandBtn?.setAttribute("aria-expanded", String(nextExpanded));
        expandBtn?.setAttribute(
          "aria-label",
          nextExpanded ? "收起输入框" : "展开输入框",
        );
      }

      function collapseEmptyComposer() {
        if (hasComposerContent()) return;
        if (input) input.value = "";
        setComposerExpanded(false);
      }

      expandBtn?.addEventListener("click", () => {
        setComposerExpanded(!form?.classList.contains("is-expanded"));
        input?.focus();
      });

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const text = input?.value.trim() ?? "";
        if (!text) return;
        if (input) {
          input.value = "";
          setComposerExpanded(false);
        }
        await sendAgentMessage(text);
      });

      input?.addEventListener("input", () => {
        collapseEmptyComposer();
      });

      input?.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" || event.isComposing) return;
        if (event.shiftKey) {
          if (!hasComposerContent()) {
            event.preventDefault();
            collapseEmptyComposer();
            return;
          }
          setComposerExpanded(true);
          return;
        }
        event.preventDefault();
        form?.requestSubmit();
      });

      const clearBtn = document.getElementById("clear-chat-btn");
      clearBtn?.addEventListener("click", () => {
        const stream = chatStreamEl();
        if (!stream) return;
        stream.innerHTML = `<div class="agent-empty">
          <span>我最近一周干了啥</span>
          <span>这个月有什么变化</span>
          <span>总结 2026-05-14 的日记</span>
        </div>`;
        attachSuggestionHandlers();
      });

      attachSuggestionHandlers();
    }

    function attachSuggestionHandlers() {
      document
        .querySelectorAll<HTMLElement>(".agent-empty span")
        .forEach((item) => {
          item.addEventListener("click", () => {
            const input = document.getElementById(
              "agent-input",
            ) as HTMLTextAreaElement | null;
            if (input) {
              input.value = item.textContent ?? "";
              input.focus();
            }
          });
        });
    }

    document.addEventListener("astro:page-load", async () => {
      syncArchiveViewport();
      attachHandlers();

      const archiveTabs = document.getElementById("archive-mobile-tabs");
      if (archiveTabs) {
        archiveTabs.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest(".m-tab");
          if (!btn) return;
          const tab = btn.getAttribute("data-mtab");
          document
            .querySelectorAll("#archive-mobile-tabs .m-tab")
            .forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
          document
            .querySelector(".archive-agent-page")
            ?.setAttribute("data-active-tab", tab || "daily");
        });
      }

      try {
        await loadDays();
      } catch (error) {
        if (redirectForPrivacyUnlock(error)) return;
        console.error(error);
        const list = document.getElementById("daily-list");
        if (list)
          list.innerHTML =
            '<div class="empty-list">归档数据加载失败，请刷新重试</div>';
      }
      if (!archiveWindow.__archiveSyncListenerAttached) {
        archiveWindow.__archiveSyncListenerAttached = true;
        window.addEventListener("our-diary:local-sync-complete", () => {
          loadDays().catch((error) => {
            if (redirectForPrivacyUnlock(error)) return;
            console.error(error);
          });
        });
      }
    });

    window.addEventListener("resize", () => {
      syncArchiveViewport();
      renderDailyList();
    });
  </script>
</Layout>
