  @media (max-width: 430px) {
    .container.header-inner {
      padding-left: 0.65rem;
      padding-right: 0.65rem;
    }

    .header-inner { gap: 0.35rem; }
    .nav-pills { gap: 0.08rem; }
    .nav-pill { padding: 0.34rem; }
    .user-area { gap: 0.28rem; }
    .announcement-btn,
    .home-sync-btn,
    .user-chip { height: 32px; }
    .announcement-btn,
    .home-sync-btn { width: 32px; }
    .user-chip { padding: 0.22rem 0.26rem; }
    .user-avatar-sm { width: 24px; height: 24px; }
    .user-chevron { display: none; }
  }
</style>

<script>
  import { getLocalPrivacyUnlockUrl, isLocalPrivacyKeyMissing, refreshLocalData } from '../lib/localFirst';
  import { clearLocalPrivacyKey } from '../lib/localCrypto';
  import { marked } from 'marked';

  type AnnouncementItem = {
    id: string;
    title: string;
    publishedAt: string;
    tag: string;
    summary: string;
    pinned?: boolean;
    body: string;
    readAt: string | null;
    unread: boolean;
  };

  type AnnouncementPayload = {
    unreadCount: number;
    announcements: AnnouncementItem[];
  };

  type AnnouncementState = {
    payload: AnnouncementPayload | null;
    currentId: string | null;
    loading: boolean;
  };

  const headerWindow = window as typeof window & {
    __userDropdownInstalled?: boolean;
    __announcementModalInstalled?: boolean;
    __changePasswordModalInstalled?: boolean;
    __announcementState?: AnnouncementState;
  };

  const announcementState = (headerWindow.__announcementState ??= {
    payload: null,
    currentId: null,
    loading: false,
  });

  function closeUserDropdowns(except?: HTMLElement): void {
    document.querySelectorAll<HTMLElement>('.user-menu.is-open').forEach((menu) => {
      if (except && menu === except) return;
      menu.classList.remove('is-open');
      menu.querySelector<HTMLButtonElement>('.user-menu-trigger')?.setAttribute('aria-expanded', 'false');
    });
  }

  function getAnnouncementButton(): HTMLButtonElement | null {
    return document.getElementById('announcement-btn') as HTMLButtonElement | null;
  }

  function getAnnouncementModal(): HTMLElement | null {
    return document.getElementById('announcement-modal');
  }

  function escapeHTML(value: unknown): string {
    const entities: Record<string, string> = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    };
    return String(value).replace(/[&<>"']/g, (char: string) => entities[char] ?? char);
  }

  function formatAnnouncementDate(value: string): string {
    const [year, month, day] = value.split('-');
    if (!year || !month || !day) return value;
    return `${year}.${month}.${day}`;
  }



  function setAnnouncementDot(unreadCount: number): void {
    const btn = getAnnouncementButton();
    if (!btn) return;
    btn.classList.toggle('has-alert', unreadCount > 0);
    btn.title = unreadCount > 0 ? `有 ${unreadCount} 条未读公告` : '查看公告';
  }

  function setAnnouncementOpen(open: boolean): void {
    const modal = getAnnouncementModal();
    const btn = getAnnouncementButton();
    modal?.classList.toggle('is-open', open);
    modal?.setAttribute('aria-hidden', String(!open));
    btn?.classList.toggle('is-open', open);
    btn?.setAttribute('aria-expanded', String(open));
    document.body.classList.toggle('announcement-lock', open);
  }

  function getChangePasswordModal(): HTMLElement | null {
    return document.getElementById('change-password-modal');
  }

  function getChangePasswordDialog(): HTMLElement | null {
    return getChangePasswordModal()?.querySelector<HTMLElement>('.password-dialog') ?? null;
  }

  function getChangePasswordStatus(): HTMLElement | null {
    return document.getElementById('change-password-status');
  }

  function setPasswordStatus(message: string, type: 'idle' | 'error' | 'success' = 'idle'): void {
    const status = getChangePasswordStatus();
    if (!status) return;
    status.textContent = message;
    status.classList.toggle('is-error', type === 'error');
    status.classList.toggle('is-success', type === 'success');
  }

  function setPasswordBusy(busy: boolean, label = '确认修改'): void {
    const form = document.getElementById('change-password-form') as HTMLFormElement | null;
    const submit = document.getElementById('change-password-submit') as HTMLButtonElement | null;
    const labelEl = submit?.querySelector<HTMLElement>('.password-submit-label');
    form?.querySelectorAll<HTMLInputElement | HTMLButtonElement>('input, button').forEach((control) => {
      control.disabled = busy;
    });
    submit?.classList.toggle('is-loading', busy);
    if (labelEl) labelEl.textContent = label;
  }

  function resetChangePasswordForm(): void {
    const form = document.getElementById('change-password-form') as HTMLFormElement | null;
    const success = document.getElementById('change-password-success');
    getChangePasswordDialog()?.classList.remove('is-success');
    form?.reset();
    success?.setAttribute('aria-hidden', 'true');
    setPasswordBusy(false);
    setPasswordStatus('');
  }

  function setChangePasswordOpen(open: boolean): void {
    const modal = getChangePasswordModal();
    modal?.classList.toggle('is-open', open);
    modal?.setAttribute('aria-hidden', String(!open));
    document.body.classList.toggle('password-lock', open);
    if (open) {
      closeUserDropdowns();
      closeAnnouncementModal();
      resetChangePasswordForm();
      window.setTimeout(() => {
        document.getElementById('current-password')?.focus();
      }, 30);
    }
  }

  function clearLocalSessionForPasswordChange(): void {
    try {
      clearLocalPrivacyKey();
      indexedDB.deleteDatabase('our-diary-local');
    } catch {}
  }

  function renderAnnouncementLoading(): void {
    const list = document.getElementById('announcement-list');
    const detail = document.getElementById('announcement-detail');
    const markAll = document.getElementById('announcement-mark-all') as HTMLButtonElement | null;
    
    const skListHtml = Array(4).fill(
      '<div class="sk-list-item"><div class="sk-row"><div class="sk-block sk-title"></div><div class="sk-block sk-badge"></div></div><div class="sk-row"><div class="sk-block sk-date"></div><div class="sk-block sk-tag"></div></div><div class="sk-block sk-summary"></div><div class="sk-block sk-summary-short"></div></div>'
    ).join('');
    
    const skDetailHtml = '<div class="sk-detail-card"><div class="sk-block sk-detail-title"></div><div class="sk-block sk-detail-meta"></div><div class="sk-block sk-detail-p1"></div><div class="sk-block sk-detail-p2"></div><div class="sk-block sk-detail-p3"></div><div class="sk-block sk-detail-p4"></div><div class="sk-block sk-detail-p1"></div><div class="sk-block sk-detail-p2"></div></div>';

    if (list) list.innerHTML = skListHtml;
    if (detail) detail.innerHTML = skDetailHtml;
    if (markAll) markAll.disabled = true;
  }

  function renderAnnouncementError(): void {
    const list = document.getElementById('announcement-list');
    const detail = document.getElementById('announcement-detail');
    if (list) list.innerHTML = '<div class="announcement-loading">公告加载失败</div>';
    if (detail) detail.innerHTML = '<div class="announcement-empty">暂时无法读取公告，请稍后再试</div>';
  }

  function renderAnnouncementList(): void {
    const list = document.getElementById('announcement-list');
    const payload = announcementState.payload;
    if (!list || !payload) return;

    if (payload.announcements.length === 0) {
      list.innerHTML = '<div class="announcement-loading">暂无公告</div>';
      return;
    }

    if (!announcementState.currentId || !payload.announcements.some((item) => item.id === announcementState.currentId)) {
      announcementState.currentId = payload.announcements[0]?.id ?? null;
    }

    list.innerHTML = payload.announcements
      .map((item) => {
        const active = item.id === announcementState.currentId ? ' is-active' : '';
        return `
          <button type="button" class="announcement-list-item${active}" data-announcement-id="${escapeHTML(item.id)}">
            <span class="announcement-list-row">
              <span class="announcement-list-title">${escapeHTML(item.title)}</span>
              <span class="announcement-state ${item.unread ? 'is-unread' : 'is-read'}">${item.unread ? '未读' : '已读'}</span>
            </span>
            <span class="announcement-list-row">
              <span class="announcement-list-date">${escapeHTML(formatAnnouncementDate(item.publishedAt))}</span>
              <span class="announcement-list-row">
                ${item.pinned ? '<span class="announcement-pin">置顶</span>' : ''}
                <span class="announcement-tag">${escapeHTML(item.tag)}</span>
              </span>
            </span>
            <span class="announcement-list-summary">${escapeHTML(item.summary)}</span>
          </button>
        `;
      })
      .join('');
  }

  function renderAnnouncementDetail(): void {
    const detail = document.getElementById('announcement-detail');
    const payload = announcementState.payload;
    if (!detail || !payload) return;

    const current = payload.announcements.find((item) => item.id === announcementState.currentId) ?? payload.announcements[0];
    if (!current) {
      detail.innerHTML = '<div class="announcement-empty">暂无公告</div>';
      return;
    }

    detail.innerHTML = `
      <div class="announcement-detail-card">
        <div class="announcement-detail-top">
          <div>
            <h3 class="announcement-detail-title">${escapeHTML(current.title)}</h3>
            <div class="announcement-detail-meta">
              ${current.pinned ? '置顶 · ' : ''}${escapeHTML(formatAnnouncementDate(current.publishedAt))} · ${escapeHTML(current.tag)}
            </div>
          </div>
          <button type="button" class="announcement-read-btn" data-announcement-mark-read="${escapeHTML(current.id)}" ${current.unread ? '' : 'disabled'}>
            ${current.unread ? '标为已读' : '已读'}
          </button>
        </div>
        <div class="announcement-markdown">${marked.parse(current.body, { async: false })}</div>
      </div>
    `;
  }

  function renderAnnouncements(): void {
    const payload = announcementState.payload;
    const markAll = document.getElementById('announcement-mark-all') as HTMLButtonElement | null;
    if (markAll) markAll.disabled = !payload || payload.unreadCount === 0;
    renderAnnouncementList();
    renderAnnouncementDetail();
    if (payload) setAnnouncementDot(payload.unreadCount);
  }

  async function loadAnnouncements(summaryOnly = false): Promise<AnnouncementPayload | null> {
    if (announcementState.loading && !summaryOnly) return announcementState.payload;
    if (!summaryOnly) announcementState.loading = true;

    try {
      const res = await fetch(`/api/announcements${summaryOnly ? '?summary=1' : ''}`, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('announcements failed');
      const data = (await res.json()) as AnnouncementPayload;
      setAnnouncementDot(data.unreadCount);
      if (!summaryOnly) {
        announcementState.payload = data;
        renderAnnouncements();
      }
      return data;
    } catch (error) {
      console.error(error);
      if (!summaryOnly) renderAnnouncementError();
      if (summaryOnly) setAnnouncementDot(0);
      return null;
    } finally {
      if (!summaryOnly) announcementState.loading = false;
    }
  }

  async function openAnnouncementModal(): Promise<void> {
    closeUserDropdowns();
    setAnnouncementOpen(true);
    if (!announcementState.payload) renderAnnouncementLoading();
    await loadAnnouncements(false);
    document.getElementById('announcement-close')?.focus();
  }

  function closeAnnouncementModal(): void {
    setAnnouncementOpen(false);
  }

  async function postAnnouncementAction(action: 'mark-read' | 'mark-all-read', announcementId?: string): Promise<void> {
    const res = await fetch('/api/announcements', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action, announcementId }),
    });
    if (!res.ok) throw new Error('announcement action failed');
    const data = (await res.json()) as { ok: boolean; error?: string } & AnnouncementPayload;
    if (!data.ok) throw new Error(data.error ?? 'announcement action failed');
    announcementState.payload = {
      unreadCount: data.unreadCount,
      announcements: data.announcements,
    };
    renderAnnouncements();
    window.dispatchEvent(new CustomEvent('our-diary:announcements-changed'));
  }

  async function handleChangePasswordSubmit(form: HTMLFormElement): Promise<void> {
    const data = new FormData(form);
    const currentPassword = String(data.get('currentPassword') ?? '');
    const newPassword = String(data.get('newPassword') ?? '');
    const confirmPassword = String(data.get('confirmPassword') ?? '');

    if (!currentPassword || !newPassword || !confirmPassword) {
      setPasswordStatus('请填写完整信息', 'error');
      return;
    }

    if (newPassword.length < 8) {
      setPasswordStatus('新密码至少需要 8 位', 'error');
      return;
    }

    if (newPassword !== confirmPassword) {
      setPasswordStatus('两次输入的新密码不一致', 'error');
      return;
    }

    if (newPassword === currentPassword) {
      setPasswordStatus('新密码不能和原密码相同', 'error');
      return;
    }

    setPasswordBusy(true, '同步中...');
    setPasswordStatus('正在同步本地数据...');

    try {
      try {
        await refreshLocalData();
        window.dispatchEvent(new CustomEvent('our-diary:local-sync-complete'));
      } catch (syncError) {
        if (isLocalPrivacyKeyMissing(syncError)) {
          window.location.assign(getLocalPrivacyUnlockUrl());
          return;
        }
        throw new Error('本地数据同步失败，请稍后再试');
      }

      setPasswordBusy(true, '校验中...');
      setPasswordStatus('正在校验原密码...');

      const res = await fetch('/api/change-password', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword, newPassword }),
      });
      const payload = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string; redirect?: string };

      if (!res.ok || !payload.ok) {
        const serverError = payload.error === 'Unauthorized' ? '登录状态已过期，请重新登录' : payload.error;
        throw new Error(serverError || '修改密码失败，请重试');
      }

      setPasswordStatus('密码已更新', 'success');
      setPasswordBusy(true, '已修改');
      getChangePasswordDialog()?.classList.add('is-success');
      document.getElementById('change-password-success')?.setAttribute('aria-hidden', 'false');
      clearLocalSessionForPasswordChange();

      window.setTimeout(() => {
        window.location.assign(payload.redirect ?? '/login?passwordChanged=1');
      }, 1300);
    } catch (error) {
      console.error(error);
      setPasswordBusy(false);
      setPasswordStatus(error instanceof Error ? error.message : '修改密码失败，请重试', 'error');
    }
  }

  if (!headerWindow.__userDropdownInstalled) {
    headerWindow.__userDropdownInstalled = true;

    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      const trigger = target?.closest<HTMLButtonElement>('.user-menu-trigger');
      if (trigger) {
        const menu = trigger.closest<HTMLElement>('.user-menu');
        if (!menu) return;
        const willOpen = !menu.classList.contains('is-open');
        closeUserDropdowns(menu);
        menu.classList.toggle('is-open', willOpen);
        trigger.setAttribute('aria-expanded', String(willOpen));
        return;
      }

      if (!target?.closest('.user-menu')) {
        closeUserDropdowns();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeUserDropdowns();
      }
    });
  }

  if (!headerWindow.__changePasswordModalInstalled) {
    headerWindow.__changePasswordModalInstalled = true;

    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      if (!target) return;

      if (target.closest('[data-open-change-password]')) {
        setChangePasswordOpen(true);
        return;
      }

      if (target.closest('#change-password-close') || target.closest('[data-close-change-password]') || target.id === 'change-password-modal') {
        if (!document.getElementById('change-password-submit')?.classList.contains('is-loading')) {
          setChangePasswordOpen(false);
        }
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || !getChangePasswordModal()?.classList.contains('is-open')) return;
      if (!document.getElementById('change-password-submit')?.classList.contains('is-loading')) {
        setChangePasswordOpen(false);
      }
    });
  }

  if (!headerWindow.__announcementModalInstalled) {
    headerWindow.__announcementModalInstalled = true;

    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      if (!target) return;

      if (target.closest('#announcement-btn')) {
        void openAnnouncementModal();
        return;
      }

      if (target.closest('#announcement-close') || target.id === 'announcement-modal') {
        closeAnnouncementModal();
        return;
      }

      const listItem = target.closest<HTMLElement>('[data-announcement-id]');
      if (listItem) {
        const id = listItem.dataset.announcementId;
        if (id) {
          announcementState.currentId = id;
          renderAnnouncements();
        }
        return;
      }

      const markRead = target.closest<HTMLButtonElement>('[data-announcement-mark-read]');
      if (markRead) {
        const id = markRead.dataset.announcementMarkRead;
        if (!id || markRead.disabled) return;
        markRead.disabled = true;
        markRead.textContent = '处理中...';
        postAnnouncementAction('mark-read', id).catch((error) => {
          console.error(error);
          renderAnnouncements();
        });
        return;
      }

      const markAll = target.closest<HTMLButtonElement>('#announcement-mark-all');
      if (markAll) {
        if (markAll.disabled) return;
        markAll.disabled = true;
        markAll.textContent = '处理中...';
        postAnnouncementAction('mark-all-read')
          .catch((error) => {
            console.error(error);
            renderAnnouncements();
          })
          .finally(() => {
            markAll.textContent = '全部已读';
          });
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && getAnnouncementModal()?.classList.contains('is-open')) {
        closeAnnouncementModal();
      }
    });

    window.addEventListener('our-diary:announcements-changed', () => {
      void loadAnnouncements(true);
    });
  }

  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('change-password-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === '1') return;
    form.dataset.bound = '1';

    form.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
      input.addEventListener('input', () => {
        setPasswordStatus('');
      });
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      void handleChangePasswordSubmit(form);
    });
  });

  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('logout-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === '1') return;
    form.dataset.bound = '1';
    form.addEventListener('submit', () => {
      try {
        sessionStorage.removeItem('our-diary-local:privacy-key:v1');
        indexedDB.deleteDatabase('our-diary-local');
      } catch {}
    });
  });

  async function refreshMemberRequestDot(): Promise<void> {
    const membersNav = document.querySelector<HTMLElement>('[data-nav-key="members"]');
    if (!membersNav) return;

    try {
      const res = await fetch('/api/users-data');
      if (!res.ok) {
        membersNav.classList.remove('has-alert');
        return;
      }
      const data = (await res.json()) as { receivedRequests?: unknown[] };
      membersNav.classList.toggle('has-alert', (data.receivedRequests?.length ?? 0) > 0);
    } catch (error) {
      console.error(error);
      membersNav.classList.remove('has-alert');
    }
  }

  document.addEventListener('astro:page-load', () => {
    void refreshMemberRequestDot();
    void loadAnnouncements(true);
    setAnnouncementOpen(false);
  });

  window.addEventListener('our-diary:permission-requests-changed', () => {
    void refreshMemberRequestDot();
  });

  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('home-sync-btn') as HTMLButtonElement | null;
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    const label = btn.querySelector<HTMLElement>('.home-sync-label');
    let resetTimer: number | undefined;

    const setState = (state: 'idle' | 'syncing' | 'success' | 'error') => {
      window.clearTimeout(resetTimer);
      btn.classList.toggle('is-syncing', state === 'syncing');
      btn.classList.toggle('is-success', state === 'success');
      btn.classList.toggle('is-error', state === 'error');
      btn.disabled = state === 'syncing';
      btn.title = state === 'idle' ? '同步数据' : state === 'syncing' ? '正在同步数据' : state === 'success' ? '数据已同步' : '同步失败';
      if (label) {
        label.textContent = state === 'idle' ? '同步数据' : state === 'syncing' ? '同步中...' : state === 'success' ? '已同步' : '同步失败';
      }
      if (state === 'success' || state === 'error') {
        resetTimer = window.setTimeout(() => setState('idle'), 2200);
      }
    };

    btn.addEventListener('click', async () => {
      setState('syncing');
      try {
        await refreshLocalData();
        window.dispatchEvent(new CustomEvent('our-diary:local-sync-complete'));
        setState('success');
      } catch (error) {
        if (isLocalPrivacyKeyMissing(error)) {
          window.location.assign(getLocalPrivacyUnlockUrl());
          return;
        }
        console.error(error);
        setState('error');
      }
    });
  });
</script>
