---
import Layout from '../layouts/Layout.astro';
---

<Layout title="写日记">
  <div class="diary-layout">
    <div class="editor-col">
      <div class="date-banner">
        <div class="date-main">
          <span class="date-day" id="date-day"><span class="skel" style="width:3rem;height:3rem;display:inline-block;"></span></span>
          <div class="date-info">
            <span class="date-ym" id="date-ym"><span class="skel" style="width:100px;height:1rem;display:inline-block;"></span></span>
            <span class="date-weekday" id="date-weekday"><span class="skel" style="width:60px;height:0.75rem;display:inline-block;"></span></span>
          </div>
        </div>
        <div class="diary-status-badge unsaved" id="status-badge">加载中...</div>
      </div>

      <div id="msg-area"></div>

      <div class="editor-card">
        <form method="POST" class="editor-form" id="diary-form">
          <textarea id="diary-content" name="content" class="diary-textarea" placeholder="今天的心情、想法或故事..."></textarea>
          <div class="editor-footer">
            <div class="char-counter"><span id="char-count">0</span> 字</div>
            <div class="editor-actions">
              <button type="submit" class="save-btn" id="save-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                <span id="save-label">发布日记</span>
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <div class="history-col">
      <div class="history-card-wrap">
        <div class="history-header">
          <div class="history-header-left">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="history-icon"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <h3 class="history-title">过往日记</h3>
          </div>
          <span class="history-count-badge" id="history-count">...</span>
        </div>
        <div class="history-list" id="history-list">
          {Array.from({ length: 4 }).map(() => (
            <div class="history-item">
              <div class="history-item-date">
                <span class="skel" style="width:28px;height:1.4rem;display:block;"></span>
                <span class="skel" style="width:36px;height:0.65rem;display:block;margin-top:0.25rem;"></span>
              </div>
              <div class="history-item-body">
                <div class="skel" style="width:100%;height:0.85rem;display:block;border-radius:4px;"></div>
                <div class="skel" style="width:70%;height:0.85rem;display:block;border-radius:4px;margin-top:6px;"></div>
              </div>
              <span class="skel" style="width:32px;height:32px;border-radius:9px;"></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="diary-modal" id="diary-modal" aria-hidden="true">
    <div class="diary-modal-backdrop" data-modal-close></div>
    <div class="diary-modal-panel" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="diary-modal-header">
        <button type="button" class="modal-nav-btn" id="modal-prev" aria-label="上一篇">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="modal-title-wrap">
          <h3 id="modal-title">历史日记</h3>
          <p id="modal-date"></p>
        </div>
        <button type="button" class="modal-nav-btn" id="modal-next" aria-label="下一篇">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <button type="button" class="modal-close-btn" data-modal-close aria-label="关闭">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="diary-modal-body" id="modal-content"></div>
    </div>
  </div>

  <style is:global>
    .skel { background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:6px; }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    html:has(.diary-layout) { height:100svh; overflow-y:scroll; scrollbar-gutter:stable; }
    body:has(.diary-layout) { height:100svh; overflow:hidden; }
    main.container:has(.diary-layout) { height:calc(100svh - var(--diary-header-height, 82px)); padding:clamp(0.6rem,1.3vh,1rem) 2rem clamp(0.5rem,1vh,0.75rem) !important; overflow:hidden; }
    .diary-layout { display:grid; grid-template-columns:minmax(0,1fr) 300px; gap:clamp(0.8rem,1.8vh,1.5rem); height:100%; min-height:0; overflow:hidden; }
    .editor-col { display:flex; flex-direction:column; gap:clamp(0.55rem,1.4vh,0.9rem); min-width:0; min-height:0; overflow:hidden; }
    .date-banner { display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
    .date-main { display:flex; align-items:center; gap:0.75rem; }
    .date-day { font-size:clamp(2.2rem,5.5vh,3rem); font-weight:800; line-height:1; background:linear-gradient(135deg,#6366f1,#a855f7); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .date-info { display:flex; flex-direction:column; gap:0.1rem; }
    .date-ym { font-size:0.95rem; font-weight:600; color:#334155; }
    .date-weekday { font-size:0.78rem; color:#94a3b8; }
    .diary-status-badge { display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.9rem; border-radius:999px; font-size:0.8rem; font-weight:600; }
    .diary-status-badge.saved { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); color:#059669; }
    .diary-status-badge.unsaved { background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.2); color:#d97706; }
    .toast { display:flex; align-items:center; gap:0.5rem; padding:0.65rem 1rem; border-radius:10px; font-size:0.875rem; flex-shrink:0; animation:slideIn 0.25s ease; }
    @keyframes slideIn { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:translateY(0)} }
    .toast-success { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); color:#059669; }
    .toast-error { background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#dc2626; }
    .editor-card { background:#ffffff; border:1px solid rgba(0,0,0,0.07); border-radius:18px; box-shadow:0 4px 20px rgba(0,0,0,0.06); flex:1; min-height:0; display:flex; flex-direction:column; overflow:hidden; }
    .editor-form { display:flex; flex-direction:column; height:100%; min-height:0; }
    .diary-textarea { flex:1; min-height:0; width:100%; background:transparent; border:none; outline:none; color:#1e293b; font-family:'Inter','Noto Serif SC',Georgia,serif; font-size:1.05rem; line-height:1.9; padding:clamp(1rem,2vh,1.5rem) clamp(1.1rem,2vw,1.75rem); resize:none; caret-color:#6366f1; }
    .diary-textarea::placeholder { color:#cbd5e1; }
    .editor-footer { display:flex; align-items:center; justify-content:space-between; padding:0.9rem 1.4rem; border-top:1px solid rgba(0,0,0,0.06); flex-shrink:0; }
    .char-counter { font-size:0.78rem; color:#cbd5e1; }
    .editor-actions { display:flex; align-items:center; gap:0.55rem; }
    .save-btn { display:inline-flex; align-items:center; gap:0.45rem; padding:0.6rem 1.4rem; border-radius:10px; background:linear-gradient(135deg,#6366f1,#8b5cf6); color:white; font-weight:600; font-size:0.9rem; font-family:inherit; border:none; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 14px rgba(99,102,241,0.35); }
    .save-btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(99,102,241,0.45); }
    .save-btn:disabled { opacity:0.72; cursor:not-allowed; transform:none; box-shadow:0 2px 8px rgba(99,102,241,0.22); }
    .history-col { display:flex; flex-direction:column; min-height:0; overflow:hidden; }
    .history-card-wrap { background:#ffffff; border:1px solid rgba(0,0,0,0.07); border-radius:18px; box-shadow:0 4px 20px rgba(0,0,0,0.06); flex:1; min-height:0; display:flex; flex-direction:column; overflow:hidden; }
    .history-header { display:flex; align-items:center; justify-content:space-between; flex-shrink:0; padding:clamp(0.8rem,1.8vh,1.25rem) 1.2rem; border-bottom:1px solid rgba(0,0,0,0.06); background:#f8fafc; }
    .history-header-left { display:flex; align-items:center; gap:0.5rem; }
    .history-icon { color:#6366f1; }
    .history-title { font-size:1.05rem; font-weight:700; color:#0f172a; }
    .history-count-badge { font-size:0.75rem; color:#6366f1; font-weight:600; background:rgba(99,102,241,0.1); padding:0.2rem 0.6rem; border-radius:999px; }
    .history-list { flex:1; min-height:0; overflow-y:auto; display:flex; flex-direction:column; gap:0.7rem; padding:clamp(0.75rem,1.7vh,1.25rem) 1.2rem; scrollbar-width:thin; scrollbar-color:rgba(99,102,241,0.25) transparent; }
    .history-list::-webkit-scrollbar { width:6px; }
    .history-list::-webkit-scrollbar-thumb { background:rgba(99,102,241,0.22); border-radius:999px; }
    .history-item { display:grid; grid-template-columns:auto minmax(0,1fr) auto; align-items:center; gap:0.75rem; background:#ffffff; border:1px solid rgba(0,0,0,0.06); border-radius:12px; padding:0.85rem; transition:all 0.2s ease; flex:0 0 auto; box-shadow:0 2px 8px rgba(0,0,0,0.02); overflow:hidden; }
    .history-item:hover { border-color:rgba(99,102,241,0.3); transform:translateY(-2px); box-shadow:0 6px 16px rgba(99,102,241,0.08); }
    .history-item-date { display:flex; flex-direction:column; align-items:center; justify-content:center; flex-shrink:0; width:42px; border-right:1px solid rgba(0,0,0,0.06); padding-right:0.75rem; }
    .hid-day { font-size:1.4rem; font-weight:800; color:#6366f1; line-height:1; }
    .hid-ym { font-size:0.65rem; color:#94a3b8; margin-top:0.25rem; white-space:nowrap; font-weight:500; }
    .history-item-body { min-width:0; display:flex; flex-direction:column; justify-content:center; gap:4px; flex:1; }
    .history-item-preview { font-size:0.85rem; color:#475569; line-height:1.55; word-break:break-all; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .history-view-btn { width:32px; height:32px; border-radius:9px; border:1px solid rgba(99,102,241,0.18); background:rgba(99,102,241,0.08); color:#6366f1; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.18s ease; flex-shrink:0; }
    .history-view-btn:hover { background:rgba(99,102,241,0.16); transform:translateY(-1px); }
    .diary-modal { position:fixed; inset:0; z-index:1100; display:none; align-items:center; justify-content:center; padding:2rem; }
    .diary-modal.is-open { display:flex; }
    .diary-modal-backdrop { position:absolute; inset:0; background:rgba(15,23,42,0.32); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); }
    .diary-modal-panel { position:relative; width:min(720px,calc(100vw - 3rem)); max-height:min(760px,calc(100svh - 4rem)); background:#fff; border:1px solid rgba(0,0,0,0.08); border-radius:18px; box-shadow:0 24px 80px rgba(15,23,42,0.22); display:flex; flex-direction:column; overflow:hidden; }
    .diary-modal-header { display:grid; grid-template-columns:40px minmax(0,1fr) 40px 40px; align-items:center; gap:0.65rem; padding:1rem 1.1rem; border-bottom:1px solid rgba(0,0,0,0.06); background:#f8fafc; }
    .modal-title-wrap { text-align:center; min-width:0; }
    .modal-title-wrap h3 { font-size:1.05rem; font-weight:800; color:#0f172a; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .modal-title-wrap p { font-size:0.78rem; color:#64748b; margin-top:0.1rem; }
    .modal-nav-btn,.modal-close-btn { position:relative; z-index:2; width:40px; height:40px; border-radius:12px; border:1px solid rgba(0,0,0,0.08); background:#fff; color:#64748b; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.18s ease; }
    .modal-close-btn { color:#64748b; }
    .modal-nav-btn:hover,.modal-close-btn:hover { color:#4f46e5; border-color:rgba(99,102,241,0.22); background:rgba(99,102,241,0.08); }
    .modal-nav-btn:disabled { opacity:0.38; cursor:not-allowed; background:#f8fafc; color:#94a3b8; }
    .diary-modal-body { padding:1.5rem 1.75rem; overflow-y:auto; white-space:pre-wrap; font-size:1.02rem; line-height:1.9; color:#1e293b; font-family:'Inter','Noto Serif SC',Georgia,serif; }
    body.modal-open { overflow:hidden; }
    @media(max-height:720px) and (min-width:901px){
      main.container:has(.diary-layout){padding:0.45rem 1.5rem 0.4rem !important;}
      .diary-layout{gap:0.8rem;}
      .date-ym{font-size:0.85rem;}
      .date-weekday,.diary-status-badge,.char-counter,.history-count-badge{font-size:0.68rem;}
      .history-title{font-size:0.9rem;}
      .editor-footer{padding:0.65rem 1rem;}
      .save-btn{padding:0.5rem 1rem; font-size:0.82rem;}
      .history-item-preview{-webkit-line-clamp:2;}
    }
    @media(max-width:900px){
      html:has(.diary-layout),body:has(.diary-layout){height:auto;overflow-y:auto;}
      main.container:has(.diary-layout){height:auto;overflow:visible;}
      .diary-layout{grid-template-columns:1fr;height:auto;overflow:visible;}
      .editor-col{overflow:visible;}
      .diary-textarea{min-height:300px;}
      .history-col{overflow:visible;}
      .history-list{overflow-y:visible;}
      .diary-modal{padding:1rem;}
      .diary-modal-panel{width:100%;max-height:calc(100svh - 2rem);}
    }
  </style>

  <script>
    import { navigate } from 'astro:transitions/client';
    import {
      getDiaryPageData,
      getLocalPrivacyUnlockUrl,
      isLocalPrivacyKeyMissing,
      saveDiaryLocal,
      syncPendingDiaries,
    } from '../lib/localFirst';

    type HistoryDiary = {
      id: string;
      dateStr: string;
      content: string;
      preview: string;
    };

    let existingDiaryId: string | null = null;
    let todayDateStr = '';
    let historyDiaries: HistoryDiary[] = [];
    let activeHistoryIndex = 0;
    const diaryWindow = window as typeof window & {
      __diaryModalHandlersAttached?: boolean;
      __diarySyncListenerAttached?: boolean;
    };

    function syncDiaryViewport() {
      const header = document.querySelector('.navbar');
      const headerHeight = header ? Math.ceil(header.getBoundingClientRect().height) : 82;
      document.documentElement.style.setProperty('--diary-header-height', `${headerHeight}px`);
    }

    function escapeHTML(value: unknown): string {
      const entities: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return String(value).replace(/[&<>"']/g, (char: string) => entities[char] ?? char);
    }

    function renderModalDiary(index: number) {
      const diary = historyDiaries[index];
      if (!diary) return;
      activeHistoryIndex = index;
      const [year, month, day] = diary.dateStr.split('-');
      const title = document.getElementById('modal-title');
      const date = document.getElementById('modal-date');
      const content = document.getElementById('modal-content');
      const prev = document.getElementById('modal-prev') as HTMLButtonElement | null;
      const next = document.getElementById('modal-next') as HTMLButtonElement | null;
      if (title) title.textContent = `${year}年${month}月${day}日`;
      if (date) date.textContent = `${index + 1} / ${historyDiaries.length}`;
      if (content) content.textContent = diary.content;
      if (prev) prev.disabled = index <= 0;
      if (next) next.disabled = index >= historyDiaries.length - 1;
    }

    function openDiaryModal(index: number) {
      if (!historyDiaries[index]) return;
      renderModalDiary(index);
      const modal = document.getElementById('diary-modal');
      if (!modal) return;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('modal-open');
    }

    function closeDiaryModal() {
      const modal = document.getElementById('diary-modal');
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('modal-open');
    }

    function attachHistoryButtons() {
      document.querySelectorAll<HTMLButtonElement>('[data-history-index]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const index = Number(btn.dataset.historyIndex);
          if (Number.isInteger(index)) openDiaryModal(index);
        });
      });
    }

    function attachModalHandlers() {
      if (diaryWindow.__diaryModalHandlersAttached) return;
      diaryWindow.__diaryModalHandlersAttached = true;

      document.addEventListener('click', (event) => {
        const target = event.target as Element | null;
        if (target?.closest('[data-modal-close]')) {
          event.preventDefault();
          closeDiaryModal();
          return;
        }
        if (target?.closest('#modal-prev')) {
          event.preventDefault();
          renderModalDiary(Math.max(0, activeHistoryIndex - 1));
          return;
        }
        if (target?.closest('#modal-next')) {
          event.preventDefault();
          renderModalDiary(Math.min(historyDiaries.length - 1, activeHistoryIndex + 1));
        }
      });

      document.addEventListener('keydown', (event) => {
        const modal = document.getElementById('diary-modal');
        if (!modal?.classList.contains('is-open')) return;
        if (event.key === 'Escape') closeDiaryModal();
        if (event.key === 'ArrowLeft') renderModalDiary(Math.max(0, activeHistoryIndex - 1));
        if (event.key === 'ArrowRight') renderModalDiary(Math.min(historyDiaries.length - 1, activeHistoryIndex + 1));
      });
    }

    async function loadDiaryData() {
      try {
        const data = await getDiaryPageData();

        existingDiaryId = data.existingDiary?.id ?? null;
        todayDateStr = data.todayDateStr;

        const dayEl = document.getElementById('date-day');
        const ymEl = document.getElementById('date-ym');
        const wdEl = document.getElementById('date-weekday');
        if (dayEl) dayEl.textContent = String(data.todayDay);
        if (ymEl) ymEl.textContent = `${data.todayYear}年${data.todayMonth}月`;
        if (wdEl) wdEl.textContent = data.todayWeekday;

        const badge = document.getElementById('status-badge');
        if (badge) {
          badge.className = `diary-status-badge ${data.existingDiary ? 'saved' : 'unsaved'}`;
          badge.textContent = data.existingDiary ? '今日已记录' : '今日未记录';
        }

        const ta = document.getElementById('diary-content') as HTMLTextAreaElement | null;
        const counter = document.getElementById('char-count');
        const saveLabel = document.getElementById('save-label');
        if (ta) {
          ta.value = data.existingDiary?.content ?? '';
          ta.placeholder = `今天是 ${data.todayDateStr}，记录下今天的心情、想法或故事...`;
          if (counter) counter.textContent = String(ta.value.length);
          if (saveLabel) saveLabel.textContent = data.existingDiary ? '更新日记' : '发布日记';
          ta.addEventListener('input', () => { if (counter) counter.textContent = String(ta.value.length); }, { once: false });
        }

        const countBadge = document.getElementById('history-count');
        const historyList = document.getElementById('history-list');
        historyDiaries = data.previousDiaries as HistoryDiary[];
        if (countBadge) countBadge.textContent = `${historyDiaries.length} 篇`;
        if (!historyList) return;
        if (historyDiaries.length === 0) {
          historyList.innerHTML = '<div style="text-align:center;padding:4rem 1rem;color:#94a3b8;font-size:0.875rem;">还没有历史日记</div>';
          return;
        }
        historyList.innerHTML = historyDiaries.map((d, index) => {
          const [y, m, day] = d.dateStr.split('-');
          return `<div class="history-item">
            <div class="history-item-date"><span class="hid-day">${day}</span><span class="hid-ym">${y}/${m}</span></div>
            <div class="history-item-body"><p class="history-item-preview">${escapeHTML(d.preview)}</p></div>
            <button type="button" class="history-view-btn" data-history-index="${index}" aria-label="查看 ${escapeHTML(d.dateStr)} 的完整日记">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>`;
        }).join('');
        attachHistoryButtons();
      } catch (e) {
        if (isLocalPrivacyKeyMissing(e)) {
          navigate(getLocalPrivacyUnlockUrl());
          return;
        }
        console.error(e);
      }
    }

    function attachFormHandler() {
      const form = document.getElementById('diary-form') as HTMLFormElement | null;
      if (!form) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const ta = document.getElementById('diary-content') as HTMLTextAreaElement | null;
        const content = ta?.value?.trim();
        if (!content) {
          showMsg('日记内容不能为空', true);
          return;
        }
        const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
        const saveLabel = document.getElementById('save-label');
        const idleLabel = existingDiaryId ? '更新日记' : '发布日记';
        if (saveBtn) saveBtn.disabled = true;
        if (saveLabel) saveLabel.textContent = '保存中...';
        try {
          const result = await saveDiaryLocal(todayDateStr, content);
          existingDiaryId = result.localId;
          const nextIdleLabel = '更新日记';
          const badge = document.getElementById('status-badge');
          if (badge) {
            badge.className = 'diary-status-badge saved';
            badge.textContent = '今日已记录';
          }
          if (saveLabel) saveLabel.textContent = '上传中...';
          try {
            const syncResult = await syncPendingDiaries();
            if (saveLabel) saveLabel.textContent = nextIdleLabel;
            window.dispatchEvent(new CustomEvent('our-diary:local-sync-complete'));
            showMsg(
              result.created
                ? `日记已发布，并已上传到云端${syncResult.synced > 1 ? `（共 ${syncResult.synced} 篇）` : ''}`
                : `日记已更新，并已上传到云端${syncResult.synced > 1 ? `（共 ${syncResult.synced} 篇）` : ''}`,
              false,
            );
          } catch (syncError) {
            if (isLocalPrivacyKeyMissing(syncError)) {
              navigate(getLocalPrivacyUnlockUrl());
              return;
            }
            console.error(syncError);
            if (saveLabel) saveLabel.textContent = nextIdleLabel;
            showMsg(
              result.created
                ? '日记已保存到本地，但上传到云端失败，请稍后点击同步数据重试'
                : '日记已更新到本地，但上传到云端失败，请稍后点击同步数据重试',
              true,
            );
          }
        } catch (error) {
          if (isLocalPrivacyKeyMissing(error)) {
            navigate(getLocalPrivacyUnlockUrl());
            return;
          }
          if (saveLabel) saveLabel.textContent = idleLabel;
          showMsg('保存失败，请重试', true);
        } finally {
          if (saveBtn) saveBtn.disabled = false;
        }
      });
    }

    function showMsg(text: string, isError: boolean) {
      const area = document.getElementById('msg-area');
      if (!area) return;
      area.innerHTML = `<div class="toast ${isError ? 'toast-error' : 'toast-success'}">${escapeHTML(text)}</div>`;
      setTimeout(() => { area.innerHTML = ''; }, 3000);
    }

    document.addEventListener('astro:page-load', () => {
      syncDiaryViewport();
      attachModalHandlers();
      loadDiaryData();
      attachFormHandler();
      if (!diaryWindow.__diarySyncListenerAttached) {
        diaryWindow.__diarySyncListenerAttached = true;
        window.addEventListener('our-diary:local-sync-complete', () => {
          loadDiaryData();
        });
      }
    });
    window.addEventListener('resize', syncDiaryViewport);
  </script>
</Layout>
