    }

    .loading-dots span {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #94a3b8;
      animation: dotPulse 1.05s ease-in-out infinite;
    }

    .loading-dots span:nth-child(2) {
      animation-delay: 0.14s;
    }

    .loading-dots span:nth-child(3) {
      animation-delay: 0.28s;
    }

    .msg-bubble.error {
      color: #b91c1c;
      border-color: rgba(239, 68, 68, 0.22);
