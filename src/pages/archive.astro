---
import Layout from '../layouts/Layout.astro';
---

<Layout title="日记归档">
  <div class="archive-page">
    <div class="archive-grid">
      <section class="archive-list-panel">
        <div class="archive-toolbar in-panel">
          <div class="panel-tools-inline">
            <div class="panel-tools-main">
              <div class="segmented" role="tablist" aria-label="归档视图">
                <button type="button" class="segment is-active" data-view="day">按天</button>
                <button type="button" class="segment" data-view="week">按周</button>
                <button type="button" class="segment" data-view="month">按月</button>
              </div>
              <div class="sync-filter day-only" id="sync-filter">
                <button type="button" class="sync-filter-btn is-active" data-sync-filter="all">全部</button>
                <button type="button" class="sync-filter-btn" data-sync-filter="synced">已同步</button>
                <button type="button" class="sync-filter-btn" data-sync-filter="unsynced">未同步</button>
              </div>
            </div>
            <button type="button" class="action-btn sync-selected-btn day-only" id="sync-selected-btn" disabled>同步所选</button>
          </div>
        </div>
        <div class="archive-list" id="archive-list">
          <div class="archive-item archive-item-skel">
            <div class="item-main">
              <span class="archive-skel archive-skel-title"></span>
              <span class="archive-skel archive-skel-text"></span>
              <span class="archive-skel archive-skel-text short"></span>
            </div>
          </div>
          <div class="archive-item archive-item-skel">
            <div class="item-main">
              <span class="archive-skel archive-skel-title"></span>
              <span class="archive-skel archive-skel-text"></span>
              <span class="archive-skel archive-skel-text short"></span>
            </div>
          </div>
          <div class="archive-item archive-item-skel">
            <div class="item-main">
              <span class="archive-skel archive-skel-title"></span>
              <span class="archive-skel archive-skel-text"></span>
              <span class="archive-skel archive-skel-text short"></span>
            </div>
          </div>
        </div>
        <div class="archive-pagination" id="archive-pagination">
          <button type="button" class="page-btn" id="page-prev">上一页</button>
          <span class="page-info" id="page-info">1 / 1</span>
          <button type="button" class="page-btn" id="page-next">下一页</button>
        </div>
      </section>

      <aside class="archive-detail-panel">
        <div class="panel-head">
          <h2 id="detail-title">归档详情</h2>
          <div class="archive-summary detail-summary" id="archive-summary" aria-label="统计卡片" aria-live="polite">
            <div class="summary-card archive-summary-skel">
              <div class="summary-stat"><span class="archive-skel archive-skel-line"></span><span class="archive-skel archive-skel-value"></span></div>
              <div class="summary-stat"><span class="archive-skel archive-skel-line"></span><span class="archive-skel archive-skel-value"></span></div>
              <div class="summary-stat"><span class="archive-skel archive-skel-line"></span><span class="archive-skel archive-skel-value"></span></div>
              <div class="summary-stat"><span class="archive-skel archive-skel-line"></span><span class="archive-skel archive-skel-value"></span></div>
            </div>
          </div>
        </div>
        <div class="detail-body" id="detail-body">
          <div class="detail-card detail-card-skel">
            <div class="detail-headline">
              <div class="archive-skel archive-skel-title"></div>
              <span class="archive-skel archive-skel-pill"></span>
            </div>
            <div class="detail-meta-line">
              <span class="archive-skel archive-skel-meta"></span>
              <span class="archive-skel archive-skel-meta short"></span>
            </div>
            <div class="detail-actions">
              <span class="archive-skel archive-skel-btn"></span>
              <span class="archive-skel archive-skel-btn"></span>
              <span class="archive-skel archive-skel-btn"></span>
            </div>
            <div class="archive-skel archive-skel-note"></div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="archive-modal" id="report-modal" aria-hidden="true">
    <div class="archive-modal-backdrop" data-report-modal-close></div>
    <div class="archive-modal-panel" role="dialog" aria-modal="true" aria-labelledby="report-modal-title">
      <div class="archive-modal-header">
        <div></div>
        <div class="archive-modal-title">
          <h3 id="report-modal-title">周报查看</h3>
          <p id="report-modal-subtitle"></p>
        </div>
        <button type="button" class="archive-modal-close" data-report-modal-close aria-label="关闭">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="archive-modal-body" id="report-modal-content"></div>
    </div>
  </div>

  <style is:global>
    html:has(.archive-page) {
      height: 100svh;
      overflow-y: scroll;
      scrollbar-gutter: stable;
    }

    body:has(.archive-page) {
      height: 100svh;
      overflow: hidden;
    }

    main.container:has(.archive-page) {
      height: calc(100svh - var(--archive-header-height, 82px));
      padding: clamp(0.7rem, 1.4vh, 1rem) 2rem clamp(0.7rem, 1vh, 0.9rem) !important;
      overflow: hidden;
    }

    .archive-page {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      height: 100%;
      min-height: 0;
    }

    .archive-toolbar {
      display: block;
      width: 100%;
    }
    .archive-toolbar.in-panel {
      display: grid;
      align-items: center;
      padding: clamp(0.45rem, 0.9vh, 0.62rem) 0.9rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      background: #fcfdff;
      min-height: clamp(72px, 9vh, 86px);
      box-sizing: border-box;
      --tool-font-size: clamp(0.74rem, 0.24vw + 0.68rem, 0.86rem);
      --tool-pad-x: clamp(0.5rem, 0.35vw + 0.42rem, 0.8rem);
      --tool-btn-height: clamp(30px, 2.2vw, 36px);
    }

    .archive-summary {
      display: inline-flex;
      justify-self: end;
      width: fit-content;
      max-width: 100%;
      min-width: 0;
      height: 100%;
    }
    .detail-summary .summary-card {
      min-height: 0;
      padding: 0;
    }

    .summary-card {
      display: inline-flex;
      align-items: stretch;
      gap: 0;
      width: auto;
      height: 100%;
      min-height: 54px;
      padding: 0.1rem 0;
      min-width: max-content;
    }

    .summary-stat {
      position: relative;
      min-width: 0;
      padding: 0.12rem 0.52rem 0.1rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.12rem;
    }

    .summary-stat:nth-child(1) {
      --summary-accent: #4f46e5;
    }

    .summary-stat:nth-child(2) {
      --summary-accent: #0f766e;
    }

    .summary-stat:nth-child(3) {
      --summary-accent: #d97706;
    }

    .summary-stat:nth-child(4) {
      --summary-accent: #2563eb;
    }

    .summary-stat:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 18%;
      bottom: 18%;
      width: 1px;
      background: rgba(99, 102, 241, 0.12);
    }

    .summary-label {
      font-size: 0.68rem;
      font-weight: 700;
      color: var(--summary-accent);
      line-height: 1;
    }

    .summary-value {
      font-size: 0.96rem;
      font-weight: 800;
      line-height: 1.1;
      color: var(--summary-accent);
    }

    .archive-skel {
      display: inline-block;
      background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 6px;
    }

    @keyframes shimmer {
      0% {
        background-position: 200% 0;
      }

      100% {
        background-position: -200% 0;
      }
    }

    .archive-summary-skel {
      min-height: 54px;
    }

    .archive-skel-line {
      width: 42px;
      height: 0.72rem;
      border-radius: 4px;
    }

    .archive-skel-value {
      width: 18px;
      height: 0.95rem;
      border-radius: 4px;
    }

    .archive-skel-title {
      width: 140px;
      height: 1rem;
      border-radius: 4px;
    }

    .archive-skel-text {
      width: 100%;
      height: 0.75rem;
      border-radius: 4px;
    }

    .archive-skel-text.short {
      width: 68%;
    }

    .archive-skel-pill {
      width: 72px;
      height: 1.4rem;
      border-radius: 999px;
    }

    .archive-skel-meta {
      width: 160px;
      height: 0.72rem;
      border-radius: 4px;
    }

    .archive-skel-meta.short {
      width: 120px;
    }

    .archive-skel-btn {
      width: 92px;
      height: 2.1rem;
      border-radius: 10px;
    }

    .archive-skel-note {
      width: 220px;
      height: 0.8rem;
      border-radius: 4px;
    }

    .archive-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      gap: 1rem;
      flex: 1;
      min-height: 0;
    }

    .archive-list-panel,
    .archive-detail-panel {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, 0.07);
      border-radius: 18px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .archive-list-panel {
      height: 100%;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 1rem 1.1rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      background: #f8fafc;
    }
    .archive-detail-panel > .panel-head {
      min-height: clamp(72px, 9vh, 86px);
      box-sizing: border-box;
    }
    .panel-tools-inline {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: nowrap;
      flex: 1 1 auto;
      min-width: 100%;
      width: 100%;
      white-space: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      scrollbar-width: none;
    }
    .panel-tools-inline::-webkit-scrollbar { display: none; }
    .panel-tools-main {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 0;
      flex: 1 1 auto;
    }
    .sync-filter { margin-left: 0; }
    .segmented,
    .sync-filter {
      background: #f8fafc;
      border: 1px solid rgba(15, 23, 42, 0.09);
      border-radius: 13px;
      min-height: calc(var(--tool-btn-height) + 8px);
      padding: 0.16rem;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      flex: 0 0 auto;
    }
    .segment,
    .sync-filter-btn {
      min-height: var(--tool-btn-height);
      padding: 0.3rem var(--tool-pad-x);
      border-radius: 10px;
      font-size: var(--tool-font-size);
      font-weight: 700;
      line-height: 1;
      border: none;
      background: transparent;
      color: #64748b;
      cursor: pointer;
    }
    .segment.is-active,
    .sync-filter-btn.is-active {
      background: #fff;
      color: #4338ca;
      box-shadow: 0 4px 10px rgba(67, 56, 202, 0.14);
    }
    .segment:hover,
    .sync-filter-btn:hover {
      color: #334155;
    }
    .sync-selected-btn {
      margin-left: auto;
      align-self: center;
    }
    .sync-selected-btn {
      padding: 0.3rem var(--tool-pad-x);
      min-height: var(--tool-btn-height);
      font-size: var(--tool-font-size);
      font-weight: 800;
      letter-spacing: 0;
      border-radius: 12px;
      border: 1px solid rgba(14, 116, 144, 0.24);
      color: #ffffff;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0)) padding-box,
        linear-gradient(135deg, #0f766e, #14b8a6) border-box;
      box-shadow: 0 8px 18px rgba(20, 184, 166, 0.24), inset 0 1px 0 rgba(255,255,255,0.32);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
      flex: 0 0 auto;
    }
    .sync-selected-btn:disabled {
      opacity: 0.78;
      color: #ecfeff;
      filter: saturate(0.82) brightness(0.98);
      border-color: rgba(45, 212, 191, 0.24);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0)) padding-box,
        linear-gradient(135deg, #14b8a6, #2dd4bf) border-box;
      box-shadow: 0 4px 12px rgba(20, 184, 166, 0.16), inset 0 1px 0 rgba(255,255,255,0.2);
    }
    .sync-selected-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      filter: saturate(1.05);
      box-shadow: 0 10px 22px rgba(20, 184, 166, 0.3), inset 0 1px 0 rgba(255,255,255,0.34);
    }

    .panel-head h2 {
      font-size: 1rem;
      color: #0f172a;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      padding: 0.22rem 0.55rem;
      border-radius: 999px;
      font-size: 0.74rem;
      font-weight: 700;
      color: #4f46e5;
      background: rgba(99, 102, 241, 0.1);
    }

    .archive-list,
    .detail-body {
      min-height: 0;
      overflow: auto;
      padding: 1rem;
    }

    .archive-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      flex: 1;
    }
    .archive-pagination {
      display:flex;
      align-items:center;
      justify-content:flex-end;
      gap:0.55rem;
      padding:0.62rem 1rem;
      border-top:1px solid rgba(0,0,0,0.06);
      background:#fcfdff;
      flex-shrink:0;
      margin-top:auto;
    }
    .page-btn {
      border:1px solid rgba(15,23,42,0.1);
      background:#fff;
      color:#475569;
      border-radius:8px;
      padding:0.32rem 0.64rem;
      font-size:0.78rem;
      font-weight:700;
      cursor:pointer;
    }
    .page-btn:disabled {
      opacity:0.45;
      cursor:not-allowed;
    }
    .page-info {
      font-size:0.78rem;
      font-weight:700;
      color:#64748b;
      min-width:70px;
      text-align:center;
    }

    .archive-item {
      border: 1px solid rgba(0, 0, 0, 0.06);
      border-radius: 14px;
      background: #fff;
      padding: 0.95rem 1rem;
      display: flex;
      gap: 0.85rem;
      align-items: flex-start;
      cursor: pointer;
      transition: all 0.18s ease;
    }
    .archive-item.synced { background:rgba(16,185,129,0.06); border-color:rgba(16,185,129,0.22); }
    .archive-item.unsynced { background:rgba(239,68,68,0.06); border-color:rgba(239,68,68,0.24); }
    .archive-item-left { padding-top:0.15rem; }
    .archive-item-check { width:16px; height:16px; accent-color:#0f766e; cursor:pointer; }

    .archive-item:hover {
      border-color: rgba(99, 102, 241, 0.24);
      box-shadow: 0 8px 20px rgba(99, 102, 241, 0.08);
      transform: translateY(-1px);
    }

    .archive-item.is-selected {
      border-color: rgba(99, 102, 241, 0.34);
      background: rgba(99, 102, 241, 0.04);
    }

    .archive-item-skel {
      pointer-events: none;
    }

    .archive-item-skel .item-main {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .detail-card-skel {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .item-main {
      min-width: 0;
      flex: 1;
    }

    .item-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: #0f172a;
    }

    .item-preview {
      margin-top: 0.25rem;
      color: #475569;
      font-size: 0.86rem;
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .item-tags {
      margin-top: 0.45rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .tag {
      font-size: 0.7rem;
      font-weight: 700;
      color: #64748b;
      background: #f1f5f9;
      border-radius: 999px;
      padding: 0.16rem 0.5rem;
    }

    .tag.primary {
      color: #4f46e5;
      background: rgba(99, 102, 241, 0.1);
    }
    .tag.synced { color:#047857; background:rgba(16,185,129,0.12); }
    .tag.unsynced { color:#b91c1c; background:rgba(239,68,68,0.14); }

    .detail-body {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }

    .detail-card {
      border: 1px solid rgba(99, 102, 241, 0.12);
      border-radius: 16px;
      padding: 1rem;
      background: #fbfbff;
    }

    .detail-headline {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }

    .detail-headline h3 {
      font-size: 1rem;
      color: #0f172a;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.22rem 0.6rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 800;
    }

    .status-ready {
      color: #059669;
      background: rgba(16, 185, 129, 0.1);
    }

    .status-pending,
    .status-generating {
      color: #b45309;
      background: rgba(245, 158, 11, 0.1);
    }

    .status-error {
      color: #dc2626;
      background: rgba(239, 68, 68, 0.1);
    }

    .detail-meta-line {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-bottom: 0.75rem;
      font-size: 0.84rem;
      color: #64748b;
    }

    .detail-meta-line strong {
      color: #0f172a;
      font-weight: 700;
    }

    .detail-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-top: 0.1rem;
    }

    .detail-note {
      margin-top: 0.7rem;
      font-size: 0.82rem;
      color: #94a3b8;
    }

    .action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      min-height: var(--tool-btn-height);
      border-radius: 12px;
      padding: 0.3rem var(--tool-pad-x);
      font: inherit;
      font-size: var(--tool-font-size);
      font-weight: 800;
      line-height: 1;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease, border-color 0.18s ease;
      border: 1px solid transparent;
    }

    .action-primary {
      color: #ffffff;
      border-color: rgba(14, 116, 144, 0.24);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0)) padding-box,
        linear-gradient(135deg, #0f766e, #14b8a6) border-box;
      box-shadow: 0 8px 18px rgba(20, 184, 166, 0.24), inset 0 1px 0 rgba(255,255,255,0.32);
    }

    .action-secondary {
      color: #334155;
      border-color: rgba(15, 23, 42, 0.12);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.9), rgba(248,250,252,0.95));
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
    }

    .action-danger {
      color: #b45309;
      border-color: rgba(249, 115, 22, 0.24);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.86), rgba(255,237,213,0.9));
      box-shadow: 0 4px 12px rgba(249, 115, 22, 0.12);
    }

    .action-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      box-shadow: none;
    }
    .action-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      filter: saturate(1.04);
    }

    /* Week/Month detail action set: refined, unified button system */
    .detail-actions {
      padding: 0.1rem;
      border-radius: 12px;
      background: linear-gradient(180deg, rgba(248, 250, 252, 0.82), rgba(241, 245, 249, 0.72));
      border: 1px solid rgba(15, 23, 42, 0.07);
      width: fit-content;
    }

    .detail-actions .action-btn {
      min-height: clamp(34px, 2.15vw, 38px);
      padding: 0.34rem 0.96rem;
      border-radius: 10px;
      font-size: clamp(0.8rem, 0.16vw + 0.76rem, 0.88rem);
      font-weight: 800;
      line-height: 1;
      border: 1px solid rgba(15, 23, 42, 0.12);
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      color: #334155;
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.9) inset, 0 4px 10px rgba(15, 23, 42, 0.08);
    }

    .detail-actions .action-primary {
      color: #ffffff;
      border-color: rgba(79, 70, 229, 0.34);
      background: linear-gradient(135deg, #6366f1, #7c3aed);
      box-shadow: 0 8px 18px rgba(99, 102, 241, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.24);
    }

    .detail-actions .action-secondary {
      color: #1f2937;
      border-color: rgba(148, 163, 184, 0.35);
      background: linear-gradient(180deg, #ffffff, #eef2f7);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.92) inset, 0 4px 10px rgba(148, 163, 184, 0.18);
    }

    .detail-actions .action-danger {
      color: #b45309;
      border-color: rgba(249, 115, 22, 0.3);
      background: linear-gradient(180deg, #fff7ed, #ffedd5);
      box-shadow: 0 4px 10px rgba(249, 115, 22, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .detail-actions .action-btn:disabled {
      opacity: 0.48;
      filter: saturate(0.65);
      box-shadow: none;
    }

    .detail-actions .action-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      filter: saturate(1.05);
    }

    .loading-line {
      color: #64748b;
      font-size: 0.9rem;
    }

    .empty-detail {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 320px;
      color: #64748b;
    }

    .empty-icon {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .archive-modal {
      position: fixed;
      inset: 0;
      z-index: 1100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .archive-modal.is-open {
      display: flex;
    }

    .archive-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.32);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }

    .archive-modal-panel {
      position: relative;
      width: min(760px, calc(100vw - 3rem));
      max-height: min(760px, calc(100svh - 4rem));
      background: #fff;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 18px;
      box-shadow: 0 24px 80px rgba(15, 23, 42, 0.22);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .archive-modal-header {
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr) 40px;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 1.1rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      background: #f8fafc;
    }

    .archive-modal-title {
      text-align: center;
      min-width: 0;
    }

    .archive-modal-title h3 {
      font-size: 1.05rem;
      font-weight: 800;
      color: #0f172a;
      margin: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .archive-modal-title p {
      font-size: 0.78rem;
      color: #64748b;
      margin-top: 0.1rem;
    }

    .archive-modal-close {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      background: #fff;
      color: #64748b;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.18s ease;
    }

    .archive-modal-close:hover {
      color: #4f46e5;
      border-color: rgba(99, 102, 241, 0.22);
      background: rgba(99, 102, 241, 0.08);
    }

    .archive-modal-body {
      padding: 1.4rem 1.6rem;
      overflow-y: auto;
      white-space: pre-wrap;
      font-size: 1rem;
      line-height: 1.9;
      color: #1e293b;
      font-family: 'Inter', 'Noto Serif SC', Georgia, serif;
    }

    .detail-report-raw {
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
      line-height: 1.9;
    }

    body.archive-modal-open {
      overflow: hidden;
    }

    @media (max-width: 980px) {
      main.container:has(.archive-page) {
        height: auto;
        overflow: visible;
      }

      html:has(.archive-page),
      body:has(.archive-page) {
        height: auto;
        overflow-y: auto;
      }

      .archive-grid {
        grid-template-columns: 1fr;
      }

      .archive-toolbar {
        grid-template-columns: 1fr;
      }

      .archive-summary {
        width: 100%;
      }

    }

    @media (max-width: 640px) {
      .segmented {
        width: 100%;
        justify-content: space-between;
      }

      .segment {
        flex: 1;
      }

      .panel-tools-inline .segmented {
        width: auto;
        justify-content: flex-start;
      }

      .panel-tools-inline .segment {
        flex: 0 0 auto;
      }

      .summary-card {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        width: 100%;
        min-height: 0;
        min-width: 0;
      }

      .summary-stat {
        padding: 0.16rem 0.48rem 0.12rem;
      }

      .summary-stat:not(:last-child)::after {
        display: none;
      }

      .summary-stat:nth-child(odd) {
        border-right: 1px solid rgba(99, 102, 241, 0.1);
      }

      .summary-stat:nth-child(-n + 2) {
        border-bottom: 1px solid rgba(99, 102, 241, 0.1);
        padding-bottom: 0.45rem;
      }

      .summary-stat:nth-child(n + 3) {
        padding-top: 0.45rem;
      }

    }
  </style>

  <script>
    import { ensureBootstrap, getArchiveDiaryDaysLocal, syncSelectedDiaries } from '../lib/localFirst';
    type ReportStatus = 'PENDING' | 'GENERATING' | 'READY' | 'ERROR';
    type ArchiveMode = 'day' | 'week' | 'month';

    type DayItem = {
      id: string;
      dateStr: string;
      content: string;
      preview: string;
      updatedAt: string;
    };

    type LocalDayItem = {
      id: string;
      dateStr: string;
      content: string;
      preview: string;
      updatedAt: string;
      synced: boolean;
    };

    type ReportItem = {
      id: string;
      status: ReportStatus;
      title: string;
      content: string | null;
      error: string | null;
      modelName: string | null;
      createdAt: string;
      updatedAt: string;
    };

    type GroupItem = {
      periodStart: string;
      periodEnd: string;
      title: string;
      count: number;
      latestDateStr: string;
      latestPreview: string;
      report: ReportItem | null;
    };

    type ArchiveData = {
      summary: {
        totalDiaries: number;
        totalReports: number;
        currentWeekCount: number;
        currentMonthCount: number;
      };
      diaryDays: DayItem[];
      weeklyGroups: GroupItem[];
      monthlyGroups: GroupItem[];
      reports: ReportItem[];
    };

    const state = {
      mode: 'day' as ArchiveMode,
      data: null as ArchiveData | null,
      localDiaryDays: [] as LocalDayItem[],
      syncFilter: 'all' as 'all' | 'synced' | 'unsynced',
      selectedLocalIds: new Set<string>(),
      pageByMode: { day: 1, week: 1, month: 1 } as Record<ArchiveMode, number>,
      selectedKey: '' as string,
      pollTimer: null as number | null,
    };

    function escapeHTML(value: unknown): string {
      return String(value).replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char] ?? char));
    }

    function syncArchiveViewport() {
      const header = document.querySelector('.navbar');
      const headerHeight = header ? Math.ceil(header.getBoundingClientRect().height) : 82;
      document.documentElement.style.setProperty('--archive-header-height', `${headerHeight}px`);
    }

    function formatDateLabel(dateStr: string) {
      const [y, m, d] = dateStr.split('-');
      return `${y}.${m}.${d}`;
    }

    function setSegmentActive() {
      document.querySelectorAll<HTMLElement>('.segment').forEach((btn) => {
        btn.classList.toggle('is-active', btn.dataset.view === state.mode);
      });
    }

    function setSelectedItem(key: string) {
      state.selectedKey = key;
      document.querySelectorAll<HTMLElement>('.archive-item').forEach((item) => {
        item.classList.toggle('is-selected', item.dataset.key === key);
      });
    }

    function reportStatusLabel(status: ReportStatus | undefined) {
      if (status === 'READY') return '已生成';
      if (status === 'GENERATING') return '生成中';
      if (status === 'ERROR') return '失败';
      if (status === 'PENDING') return '待生成';
      return '未生成';
    }

    function getFilteredLocalDays(): LocalDayItem[] {
      if (state.syncFilter === 'synced') return state.localDiaryDays.filter((d) => d.synced);
      if (state.syncFilter === 'unsynced') return state.localDiaryDays.filter((d) => !d.synced);
      return state.localDiaryDays;
    }

    function getCurrentPage() {
      return state.pageByMode[state.mode] ?? 1;
    }

    function setCurrentPage(page: number) {
      state.pageByMode[state.mode] = Math.max(1, page);
    }

    function getPerPage(mode: ArchiveMode): number {
      const viewportH = window.innerHeight || 900;
      const compact = viewportH < 820;
      if (mode === 'day') return compact ? 3 : 4;
      return compact ? 5 : 6;
    }

    function paginate<T>(items: T[]) {
      const perPage = getPerPage(state.mode);
      const totalPages = Math.max(1, Math.ceil(items.length / perPage));
      const page = Math.min(getCurrentPage(), totalPages);
      setCurrentPage(page);
      const start = (page - 1) * perPage;
      return {
        page,
        perPage,
        totalPages,
        pageItems: items.slice(start, start + perPage),
      };
    }

    function refreshPagination(total: number, page: number, totalPages: number) {
      const bar = document.getElementById('archive-pagination');
      const prev = document.getElementById('page-prev') as HTMLButtonElement | null;
      const next = document.getElementById('page-next') as HTMLButtonElement | null;
      const info = document.getElementById('page-info');
      if (!bar || !prev || !next || !info) return;
      bar.style.display = total > 0 ? 'flex' : 'none';
      prev.disabled = page <= 1;
      next.disabled = page >= totalPages;
      info.textContent = `${page} / ${totalPages}`;
    }

    function refreshListTools() {
      const tools = document.querySelector('.panel-tools-inline') as HTMLElement | null;
      const syncBtn = document.getElementById('sync-selected-btn') as HTMLButtonElement | null;
      const filter = document.getElementById('sync-filter');
      const dayOnlyControls = document.querySelectorAll<HTMLElement>('.day-only');
      const dayMode = state.mode === 'day';
      if (tools) tools.style.display = 'flex';
      dayOnlyControls.forEach((el) => {
        el.style.display = dayMode ? '' : 'none';
      });
      if (filter) filter.style.display = dayMode ? 'inline-flex' : 'none';
      if (!dayMode) return;
      const pendingVisible = getFilteredLocalDays().filter((d) => !d.synced).map((d) => d.id);
      const selectedPending = pendingVisible.filter((id) => state.selectedLocalIds.has(id));
      if (syncBtn) syncBtn.disabled = selectedPending.length === 0;
    }

    function getCurrentReportGroups(): GroupItem[] {
      if (!state.data) return [];
      if (state.mode === 'week') return state.data.weeklyGroups;
      if (state.mode === 'month') return state.data.monthlyGroups;
      return [];
    }

    function getSelectedDay(): LocalDayItem | null {
      if (!state.data || state.mode !== 'day') return null;
      return state.localDiaryDays.find((day) => day.dateStr === state.selectedKey) ?? null;
    }

    function getSelectedGroup(): GroupItem | null {
      if (!state.data || state.mode === 'day') return null;
      const groups = state.mode === 'week' ? state.data.weeklyGroups : state.data.monthlyGroups;
      return groups.find((group) => group.periodStart === state.selectedKey) ?? null;
    }

    function renderSummary() {
      const el = document.getElementById('archive-summary');
      if (!el || !state.data) return;
      const { summary } = state.data;
      el.innerHTML = `
        <div class="summary-card">
          <div class="summary-stat"><span class="summary-label">总日记</span><span class="summary-value">${summary.totalDiaries}</span></div>
          <div class="summary-stat"><span class="summary-label">总报告</span><span class="summary-value">${summary.totalReports}</span></div>
          <div class="summary-stat"><span class="summary-label">本周日记</span><span class="summary-value">${summary.currentWeekCount}</span></div>
          <div class="summary-stat"><span class="summary-label">本月日记</span><span class="summary-value">${summary.currentMonthCount}</span></div>
        </div>`;
    }

    function renderList() {
      const list = document.getElementById('archive-list');
      const hint = document.getElementById('archive-hint');
      if (!list || !state.data) return;
      if (hint) {
        hint.textContent = state.mode === 'day'
          ? '按天查看每一天的内容。'
          : '生成后会保存在这里，之后可以直接回看。';
      }

      if (state.mode === 'day') {
        const days = getFilteredLocalDays();
        const paged = paginate(days);
        if (days.length === 0) {
          refreshPagination(0, 1, 1);
          list.innerHTML = '<div class="empty-detail"><div class="empty-icon">📭</div><p>这里还没有内容。</p></div>';
          return;
        }
        list.innerHTML = paged.pageItems.map((day) => `
          <div class="archive-item ${day.synced ? 'synced' : 'unsynced'}" data-key="${day.dateStr}" data-local-id="${day.id}">
            <div class="archive-item-left"><input type="checkbox" class="archive-item-check" data-select-id="${day.id}" ${state.selectedLocalIds.has(day.id) ? 'checked' : ''} ${day.synced ? 'disabled' : ''} /></div>
            <div class="item-main">
              <div class="item-title">${formatDateLabel(day.dateStr)}</div>
              <div class="item-preview">${escapeHTML(day.preview)}</div>
              <div class="item-tags"><span class="tag primary">日记</span><span class="tag ${day.synced ? 'synced' : 'unsynced'}">${day.synced ? '已同步' : '未同步'}</span><span class="tag">${escapeHTML(day.updatedAt.slice(0, 10))}</span></div>
            </div>
          </div>`).join('');
        refreshPagination(days.length, paged.page, paged.totalPages);
      } else {
        const groups = getCurrentReportGroups();
        const paged = paginate(groups);
        if (groups.length === 0) {
          refreshPagination(0, 1, 1);
          list.innerHTML = '<div class="empty-detail"><div class="empty-icon">📭</div><p>这里还没有内容。</p></div>';
          return;
        }
        list.innerHTML = paged.pageItems.map((group) => {
          const status = group.report?.status ?? 'PENDING';
          const badgeText = group.report
            ? reportStatusLabel(status)
            : '未生成';
          return `
            <div class="archive-item" data-key="${group.periodStart}">
              <div class="item-main">
                <div class="item-title">${escapeHTML(group.title)}</div>
                <div class="item-preview">${escapeHTML(group.latestPreview)}</div>
                <div class="item-tags">
                  <span class="tag primary">${group.count} 篇日记</span>
                  <span class="tag">${escapeHTML(group.latestDateStr)}</span>
                  <span class="tag">${badgeText}</span>
                </div>
              </div>
            </div>`;
        }).join('');
        refreshPagination(groups.length, paged.page, paged.totalPages);
      }

      list.querySelectorAll<HTMLElement>('.archive-item').forEach((item) => {
        item.addEventListener('click', () => {
          const key = item.dataset.key ?? '';
          setSelectedItem(key);
          renderDetail();
        });
      });

      list.querySelectorAll<HTMLInputElement>('.archive-item-check').forEach((checkbox) => {
        checkbox.addEventListener('click', (event) => {
          event.stopPropagation();
        });
        checkbox.addEventListener('change', () => {
          const id = checkbox.dataset.selectId ?? '';
          if (!id) return;
          if (checkbox.checked) state.selectedLocalIds.add(id);
          else state.selectedLocalIds.delete(id);
          refreshListTools();
        });
      });
      refreshListTools();
    }

    function reportStatusClass(status: ReportStatus | undefined) {
      if (status === 'READY') return 'status-ready';
      if (status === 'ERROR') return 'status-error';
      if (status === 'GENERATING') return 'status-generating';
      return 'status-pending';
    }

    function openReportModal(report: ReportItem, titleText: string, periodStart: string, periodEnd: string) {
      const modal = document.getElementById('report-modal');
      const modalTitle = document.getElementById('report-modal-title');
      const modalSubtitle = document.getElementById('report-modal-subtitle');
      const modalContent = document.getElementById('report-modal-content');
      if (!modal || !modalTitle || !modalSubtitle || !modalContent) return;

      modalTitle.textContent = `${titleText} 查看`;
      modalSubtitle.textContent = `${periodStart} - ${periodEnd} · ${report.status}${report.modelName ? ` · ${report.modelName}` : ''}`;
      modalContent.innerHTML = '';

      const metaLine = document.createElement('div');
      metaLine.className = 'detail-meta-line';
      metaLine.innerHTML = `<span><strong>周期</strong> ${escapeHTML(periodStart)} - ${escapeHTML(periodEnd)}</span><span><strong>状态</strong> ${escapeHTML(report.status)}</span>`;

      const body = document.createElement('div');
      body.className = 'detail-report';
      body.textContent = report.content ?? report.error ?? '暂无可显示内容';

      modalContent.append(metaLine, body);
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('archive-modal-open');
    }

    function closeReportModal() {
      const modal = document.getElementById('report-modal');
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('archive-modal-open');
    }

    function attachReportModalHandlers() {
      document.addEventListener('click', (event) => {
        const target = event.target as Element | null;
        if (target?.closest('[data-report-modal-close]')) {
          event.preventDefault();
          closeReportModal();
        }
      });

      document.addEventListener('keydown', (event) => {
        const modal = document.getElementById('report-modal');
        if (!modal?.classList.contains('is-open')) return;
        if (event.key === 'Escape') closeReportModal();
      });
    }

    async function requestGenerate(type: 'WEEK' | 'MONTH', periodStart: string) {
      const res = await fetch('/api/archive-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, periodStart, action: 'generate' }),
      });
      if (!res.ok && res.status !== 202) {
        const json = await res.json().catch(() => ({}));
        throw new Error(json.error || '生成失败');
      }
    }

    async function requestCancel(type: 'WEEK' | 'MONTH', periodStart: string) {
      const res = await fetch('/api/archive-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, periodStart, action: 'cancel' }),
      });
      if (!res.ok) {
        const json = await res.json().catch(() => ({}));
        throw new Error(json.error || '停止失败');
      }
    }

    function renderDetail() {
      const body = document.getElementById('detail-body');
      const title = document.getElementById('detail-title');
      if (!body || !title) return;

      if (state.mode === 'day') {
        const day = getSelectedDay() ?? state.localDiaryDays[0] ?? null;
        if (!day) {
          body.innerHTML = '<div class="empty-detail"><div class="empty-icon">📭</div><p>还没有日记。</p></div>';
          title.textContent = '归档详情';
          return;
        }
        title.textContent = '日记详情';
        body.innerHTML = `
          <div class="detail-card">
            <div class="detail-headline">
              <div>
                <h3>${formatDateLabel(day.dateStr)}</h3>
              </div>
              <span class="status-pill ${day.synced ? 'status-ready' : 'status-error'}">${day.synced ? '已同步' : '未同步'}</span>
            </div>
            <div class="detail-meta-line"><span><strong>更新时间</strong> ${escapeHTML(day.updatedAt.replace('T', ' ').slice(0, 16))}</span></div>
            <div class="detail-report detail-report-raw">${escapeHTML(day.content)}</div>
          </div>`;
        return;
      }

      const group = getSelectedGroup() ?? (state.mode === 'week' ? state.data?.weeklyGroups[0] : state.data?.monthlyGroups[0]) ?? null;
      if (!group) {
        body.innerHTML = '<div class="empty-detail"><div class="empty-icon">📭</div><p>还没有可归档的周报或月报。</p></div>';
        title.textContent = '归档详情';
        return;
      }

      title.textContent = state.mode === 'week' ? '周档详情' : '月档详情';
      const report = group.report;
      const reportState = report?.status ?? null;
      const isBusy = reportState === 'GENERATING' || reportState === 'PENDING';
      const buttonLabel = reportState === 'READY' ? '重新生成' : '生成报告';
      const refreshButton = report ? `<button type="button" class="action-btn action-secondary" data-refresh-report="${report.id}">刷新状态</button>` : '';
      const stopButton = isBusy ? `<button type="button" class="action-btn action-danger" data-stop-report="${group.periodStart}">停止生成</button>` : '';
      const generateDisabled = isBusy ? 'disabled' : '';
      const statusClass = reportStatusClass(report?.status);
      const canViewReport = report?.status === 'READY' && !!report.content;
      const summaryNote =
        report?.status === 'READY'
          ? '报告已生成，可以查看完整内容。'
          : report?.status === 'GENERATING'
            ? '报告正在生成中，完成后可查看。'
            : report?.status === 'ERROR'
              ? '报告生成失败，可重新生成。'
              : '当前周期还没有报告。';

      body.innerHTML = `
        <div class="detail-card">
          <div class="detail-headline">
            <div>
              <h3>${escapeHTML(group.title)}</h3>
            </div>
            <span class="status-pill ${statusClass}">${reportStatusLabel(report?.status)}</span>
          </div>
          <div class="detail-meta-line"><span><strong>周期</strong> ${escapeHTML(group.periodStart)} - ${escapeHTML(group.periodEnd)}</span><span><strong>日记数量</strong> ${group.count} 篇</span></div>
          <div class="detail-actions">
            <button type="button" class="action-btn action-primary" data-generate-report="${group.periodStart}" ${generateDisabled}>${buttonLabel}</button>
            ${stopButton}
            ${refreshButton}
            <button type="button" class="action-btn action-secondary" data-open-report ${canViewReport ? '' : 'disabled'}>查看</button>
          </div>
          <div class="detail-note">${summaryNote}</div>
        </div>`;

      body.querySelector<HTMLButtonElement>('[data-generate-report]')?.addEventListener('click', async (event) => {
        const btn = event.currentTarget as HTMLButtonElement;
        btn.disabled = true;
        try {
          await requestGenerate(state.mode === 'week' ? 'WEEK' : 'MONTH', group.periodStart);
          await loadArchiveData(false);
          state.selectedKey = group.periodStart;
          renderDetail();
          setSelectedItem(group.periodStart);
        } finally {
          btn.disabled = false;
        }
      });

      body.querySelector<HTMLButtonElement>('[data-refresh-report]')?.addEventListener('click', async () => {
        await loadArchiveData(false);
        renderDetail();
      });

      body.querySelector<HTMLButtonElement>('[data-stop-report]')?.addEventListener('click', async () => {
        const btn = body.querySelector<HTMLButtonElement>('[data-stop-report]');
        if (btn) btn.disabled = true;
        try {
          await requestCancel(state.mode === 'week' ? 'WEEK' : 'MONTH', group.periodStart);
          await loadArchiveData(false);
          state.selectedKey = group.periodStart;
          renderDetail();
          setSelectedItem(group.periodStart);
        } finally {
          if (btn) btn.disabled = false;
        }
      });

      body.querySelector<HTMLButtonElement>('[data-open-report]')?.addEventListener('click', () => {
        if (!report || !report.content) return;
        openReportModal(report, group.title, group.periodStart, group.periodEnd);
      });
    }

    async function loadArchiveData(resetSelection = true) {
      await ensureBootstrap();
      const res = await fetch('/api/archive-data');
      if (!res.ok) return;
      const data = (await res.json()) as ArchiveData;
      state.data = data;
      const localDays = await getArchiveDiaryDaysLocal();
      state.localDiaryDays = localDays.map((d) => ({
        id: d.localId,
        dateStr: d.dateStr,
        content: d.content,
        preview: d.preview,
        updatedAt: d.updatedAt,
        synced: !d.needsSync,
      }));
      renderSummary();
      renderList();
      if (resetSelection || !state.selectedKey) {
        if (state.mode === 'day') {
          state.selectedKey = getFilteredLocalDays()[(getCurrentPage() - 1) * getPerPage('day')]?.dateStr ?? getFilteredLocalDays()[0]?.dateStr ?? '';
        } else if (state.mode === 'week') {
          const all = data.weeklyGroups;
          state.selectedKey = all[(getCurrentPage() - 1) * getPerPage('week')]?.periodStart ?? all[0]?.periodStart ?? '';
        } else {
          const all = data.monthlyGroups;
          state.selectedKey = all[(getCurrentPage() - 1) * getPerPage('month')]?.periodStart ?? all[0]?.periodStart ?? '';
        }
      }
      renderDetail();
      setSelectedItem(state.selectedKey);
    }

    function switchMode(mode: ArchiveMode) {
      state.mode = mode;
      state.selectedKey = '';
      setCurrentPage(1);
      setSegmentActive();
      renderList();
      if (state.mode === 'day') {
        state.selectedKey = getFilteredLocalDays()[0]?.dateStr ?? '';
      } else if (state.mode === 'week') {
        state.selectedKey = state.data?.weeklyGroups[0]?.periodStart ?? '';
      } else {
        state.selectedKey = state.data?.monthlyGroups[0]?.periodStart ?? '';
      }
      renderDetail();
      setSelectedItem(state.selectedKey);
    }

    function startPolling() {
      if (state.pollTimer) window.clearInterval(state.pollTimer);
      state.pollTimer = window.setInterval(async () => {
        if (!state.data) return;
        const pending = state.data.reports.some((item) => item.status === 'PENDING' || item.status === 'GENERATING');
        if (!pending) return;
        await loadArchiveData(false);
        if (state.selectedKey) {
          renderDetail();
          setSelectedItem(state.selectedKey);
        }
      }, 3000);
    }

    document.addEventListener('astro:page-load', async () => {
      syncArchiveViewport();
      attachReportModalHandlers();
      setSegmentActive();
      await loadArchiveData();
      startPolling();
      document.querySelectorAll<HTMLElement>('.segment').forEach((btn) => {
        btn.addEventListener('click', () => switchMode(btn.dataset.view as ArchiveMode));
      });
      document.querySelectorAll<HTMLElement>('.sync-filter-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const next = (btn.dataset.syncFilter ?? 'all') as 'all' | 'synced' | 'unsynced';
          state.syncFilter = next;
          document.querySelectorAll<HTMLElement>('.sync-filter-btn').forEach((item) => {
            item.classList.toggle('is-active', item.dataset.syncFilter === next);
          });
          if (state.mode === 'day') {
            const days = getFilteredLocalDays();
            if (!days.some((d) => d.dateStr === state.selectedKey)) {
              state.selectedKey = days[0]?.dateStr ?? '';
            }
            renderList();
            renderDetail();
            setSelectedItem(state.selectedKey);
          }
        });
      });

      const syncBtn = document.getElementById('sync-selected-btn') as HTMLButtonElement | null;
      syncBtn?.addEventListener('click', async () => {
        const pendingVisible = getFilteredLocalDays().filter((d) => !d.synced).map((d) => d.id);
        const targetIds = pendingVisible.filter((id) => state.selectedLocalIds.has(id));
        if (!targetIds.length) return;
        syncBtn.disabled = true;
        const oldText = syncBtn.textContent;
        syncBtn.textContent = '同步中...';
        try {
          await syncSelectedDiaries(targetIds);
          targetIds.forEach((id) => state.selectedLocalIds.delete(id));
          await loadArchiveData(false);
          if (state.mode === 'day') {
            const days = getFilteredLocalDays();
            if (!days.some((d) => d.dateStr === state.selectedKey)) state.selectedKey = days[0]?.dateStr ?? '';
            renderList();
            renderDetail();
            setSelectedItem(state.selectedKey);
          }
        } finally {
          syncBtn.disabled = false;
          syncBtn.textContent = oldText ?? '同步所选';
          refreshListTools();
        }
      });

      refreshListTools();

      const prevBtn = document.getElementById('page-prev') as HTMLButtonElement | null;
      const nextBtn = document.getElementById('page-next') as HTMLButtonElement | null;
      prevBtn?.addEventListener('click', () => {
        setCurrentPage(getCurrentPage() - 1);
        renderList();
        if (state.mode === 'day') {
          const days = getFilteredLocalDays();
          const keys = days.map((x) => x.dateStr);
          if (!keys.includes(state.selectedKey)) {
            const paged = paginate(days);
            state.selectedKey = paged.pageItems[0]?.dateStr ?? '';
            renderDetail();
            setSelectedItem(state.selectedKey);
          }
          return;
        }
        const groups = getCurrentReportGroups();
        const keys = groups.map((x) => x.periodStart);
        if (!keys.includes(state.selectedKey)) {
          const paged = paginate(groups);
          state.selectedKey = paged.pageItems[0]?.periodStart ?? '';
          renderDetail();
          setSelectedItem(state.selectedKey);
        }
      });
      nextBtn?.addEventListener('click', () => {
        setCurrentPage(getCurrentPage() + 1);
        renderList();
        if (state.mode === 'day') {
          const days = getFilteredLocalDays();
          const keys = days.map((x) => x.dateStr);
          if (!keys.includes(state.selectedKey)) {
            const paged = paginate(days);
            state.selectedKey = paged.pageItems[0]?.dateStr ?? '';
            renderDetail();
            setSelectedItem(state.selectedKey);
          }
          return;
        }
        const groups = getCurrentReportGroups();
        const keys = groups.map((x) => x.periodStart);
        if (!keys.includes(state.selectedKey)) {
          const paged = paginate(groups);
          state.selectedKey = paged.pageItems[0]?.periodStart ?? '';
          renderDetail();
          setSelectedItem(state.selectedKey);
        }
      });
    });

    window.addEventListener('resize', () => {
      syncArchiveViewport();
      renderList();
      renderDetail();
      setSelectedItem(state.selectedKey);
    });
  </script>
</Layout>
