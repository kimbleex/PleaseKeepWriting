      background: #ecfdf5;
      box-shadow: 0 6px 14px rgba(15, 23, 42, 0.07);
    }

    .composer-expand-btn .icon-collapse {
      display: none;
    }

    .agent-composer.is-expanded .composer-expand-btn .icon-expand {
