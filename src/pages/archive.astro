    }

    .agent-turn {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      width: 100%;
      align-self: stretch;
    }

    .stream-stack {
      display: flex;
      flex-direction: column;
      gap: 0.42rem;
      width: 100%;
    }

    .stream-step {
      width: 100%;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.86);
      border-radius: 12px;
      color: #475569;
      font-size: 0.76rem;
      line-height: 1.45;
      box-shadow: 0 6px 16px rgba(15, 23, 42, 0.035);
      overflow: hidden;
    }

    .stream-line,
    .stream-step summary {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      min-height: 36px;
      padding: 0.42rem 0.62rem;
      list-style: none;
      cursor: default;
    }

    .stream-step.tool-step summary {
      cursor: pointer;
    }

    .stream-step summary::-webkit-details-marker {
      display: none;
    }

    .stream-spinner {
      position: relative;
      width: 16px;
      height: 16px;
      box-sizing: border-box;
      border-radius: 50%;
      border: 2px solid rgba(14, 165, 233, 0.18);
      border-top-color: #0ea5e9;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      animation: spin 0.8s linear infinite;
    }

    .stream-step.is-done .stream-spinner {
      border: 0;
      background: #10b981;
      color: #fff;
      animation: none;
    }

    .stream-step.is-done .stream-spinner::after {
      content: "✓";
      color: #fff;
      font-size: 11px;
      font-weight: 900;
      line-height: 1;
    }

    .stream-title {
      min-width: 0;
      color: #334155;
      font-weight: 850;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .stream-node {
      flex: 0 0 auto;
      color: #0369a1;
      font-weight: 900;
