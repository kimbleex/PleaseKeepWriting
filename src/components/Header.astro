  }

  .password-secondary:hover:not(:disabled) {
    background: #f8fafc;
    border-color: rgba(15, 23, 42, 0.16);
  }

  .password-primary {
    color: #ffffff;
    border: 1px solid rgba(15, 118, 110, 0.4);
