---
const { user, url } = Astro.props;
const pathname = (url as URL)?.pathname ?? '/';
const showHomeSync = true ;

type NavItem = { href: string; label: string; icon: string };
const navItems: NavItem[] = [
  {
    href: '/',
    label: '日历',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    href: '/diary',
    label: '写日记',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  },
  {
    href: '/archive',
    label: '日记归档',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8"/><path d="M3 8l1.68-4.23A2 2 0 0 1 6.54 2h10.92a2 2 0 0 1 1.86 1.77L21 8"/><path d="M10 12h4"/></svg>`,
  },
  {
    href: '/users',
    label: '成员',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
if (user.role === 'ADMIN') {
  navItems.push({
    href: '/admin',
    label: '管理',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  });
}
---

<header class="navbar">
  <div class="container header-inner">
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
      </div>
      <span class="logo-text">我们的日记</span>
    </a>

    <nav class="nav-pills">
      {navItems.map((item) => {
        const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
        return (
          <a href={item.href} class={`nav-pill${isActive ? ' active' : ''}`} data-astro-prefetch>
            <span class="nav-icon" set:html={item.icon} />
            <span class="nav-label">{item.label}</span>
          </a>
        );
      })}
    </nav>

    <div class="user-area">
      {showHomeSync && (
        <button type="button" class="home-sync-btn" id="home-sync-btn" title="同步数据" aria-live="polite">
          <span class="home-sync-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 1-15.5 6.2L3 16"/><path d="M3 16v5h5"/><path d="M3 12A9 9 0 0 1 18.5 5.8L21 8"/><path d="M21 8V3h-5"/></svg>
          </span>
          <span class="home-sync-label">同步数据</span>
        </button>
      )}
      <div class="user-chip">
        <div class="user-avatar-sm">{user.username.charAt(0).toUpperCase()}</div>
        <span class="user-chip-name">{user.username}</span>
        {user.role === 'ADMIN' && <span class="admin-dot" title="管理员"></span>}
      </div>
      <form method="POST" action="/api/logout" id="logout-form">
        <button type="submit" class="logout-btn" title="退出登录">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </form>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.06);
  }

  .header-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 2px 10px rgba(99, 102, 241, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .logo:hover .logo-icon {
    transform: rotate(-6deg) scale(1.08);
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.5);
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 700;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-pills {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .nav-pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.42rem 0.85rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    text-decoration: none;
    transition: all 0.18s ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .nav-pill:hover {
    color: #1e293b;
    background: rgba(0, 0, 0, 0.05);
  }

  .nav-pill.active {
    color: #6366f1;
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.18);
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .user-area {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .user-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.28rem 0.75rem 0.28rem 0.32rem;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .home-sync-btn {
    height: 34px;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0 0.78rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.12));
    border: 1px solid rgba(99, 102, 241, 0.22);
    color: #5b5fee;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(99, 102, 241, 0.12);
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .home-sync-btn:hover {
    transform: translateY(-1px);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.16), rgba(168, 85, 247, 0.18));
    border-color: rgba(99, 102, 241, 0.34);
    box-shadow: 0 10px 28px rgba(99, 102, 241, 0.18);
  }

  .home-sync-btn:disabled {
    cursor: default;
    transform: none;
    opacity: 0.78;
  }

  .home-sync-btn.is-syncing .home-sync-icon {
    animation: home-sync-spin 0.9s linear infinite;
  }

  .home-sync-btn.is-success {
    color: #059669;
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.22);
  }

  .home-sync-btn.is-error {
    color: #dc2626;
    background: rgba(239, 68, 68, 0.09);
    border-color: rgba(239, 68, 68, 0.22);
  }

  .home-sync-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes home-sync-spin {
    to { transform: rotate(360deg); }
  }

  .user-avatar-sm {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.72rem;
    flex-shrink: 0;
  }

  .user-chip-name {
    font-size: 0.82rem;
    font-weight: 500;
    color: #475569;
    max-width: 120px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .admin-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 5px rgba(99, 102, 241, 0.55);
    flex-shrink: 0;
  }

  .logout-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.18s;
    flex-shrink: 0;
  }

  .logout-btn:hover {
    background: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.2);
    color: #ef4444;
  }

  @media (max-width: 760px) {
    .logo-text { display: none; }
    .nav-label { display: none; }
    .nav-pill { padding: 0.45rem; }
    .home-sync-btn { width: 34px; padding: 0; justify-content: center; }
    .home-sync-label { display: none; }
    .user-chip-name { display: none; }
    .header-inner { gap: 0.7rem; }
  }
</style>

<script>
  import { getLocalPrivacyUnlockUrl, isLocalPrivacyKeyMissing, refreshLocalData } from '../lib/localFirst';

  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('logout-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === '1') return;
    form.dataset.bound = '1';
    form.addEventListener('submit', () => {
      try {
        sessionStorage.removeItem('our-diary-local:privacy-key:v1');
        indexedDB.deleteDatabase('our-diary-local');
      } catch {}
    });
  });

  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('home-sync-btn') as HTMLButtonElement | null;
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    const label = btn.querySelector<HTMLElement>('.home-sync-label');
    let resetTimer: number | undefined;

    const setState = (state: 'idle' | 'syncing' | 'success' | 'error') => {
      window.clearTimeout(resetTimer);
      btn.classList.toggle('is-syncing', state === 'syncing');
      btn.classList.toggle('is-success', state === 'success');
      btn.classList.toggle('is-error', state === 'error');
      btn.disabled = state === 'syncing';
      btn.title = state === 'idle' ? '同步数据' : state === 'syncing' ? '正在同步数据' : state === 'success' ? '数据已同步' : '同步失败';
      if (label) {
        label.textContent = state === 'idle' ? '同步数据' : state === 'syncing' ? '同步中...' : state === 'success' ? '已同步' : '同步失败';
      }
      if (state === 'success' || state === 'error') {
        resetTimer = window.setTimeout(() => setState('idle'), 2200);
      }
    };

    btn.addEventListener('click', async () => {
      setState('syncing');
      try {
        await refreshLocalData();
        window.dispatchEvent(new CustomEvent('our-diary:local-sync-complete'));
        setState('success');
      } catch (error) {
        if (isLocalPrivacyKeyMissing(error)) {
          window.location.assign(getLocalPrivacyUnlockUrl());
          return;
        }
        console.error(error);
        setState('error');
      }
    });
  });
</script>
